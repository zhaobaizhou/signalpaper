---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE } from '../config/site';
import { getAlternateLinks } from '../lib/discovery';
import { buildBreadcrumbSchema } from '../lib/schema';

const alternateLinks = getAlternateLinks({ en: '/about', zh: '/zh/about' });
const schema = buildBreadcrumbSchema([
  { name: SITE.name, path: '/' },
  { name: 'About', path: '/about' },
]);
---

<BaseLayout
  title="About"
  description={`${SITE.name} is a minimalist Astro theme for builders, writers, and AI-native personal sites.`}
  alternateLinks={alternateLinks}
  schema={schema}
>
  <Header />

  <main id="main-content" role="main" class="container fade-in">
    <div class="prose" data-pagefind-body>
      <h1>About SignalPaper</h1>
      <p>
        SignalPaper is a minimalist Astro theme for builders, writers, and AI-native personal sites who want a durable home for writing and projects.
      </p>
      <p>
        The default site is bilingual by design, optimized for long-form reading, and structured to support both search engines and AI-native discovery from day one.
      </p>
      <p>
        Start with the <a href="/features">feature overview</a>, the <a href="/docs">documentation</a>, or the <a href="/faq">FAQ</a> when adapting the theme.
      </p>
      <p>
        For machine-readable discovery surfaces, review <a href="/for-agents">For Agents</a>, <a href="/llms.txt">llms.txt</a>, and <a href="/llms-full.txt">llms-full.txt</a>.
      </p>
      <h2>Who it is for</h2>
      <p>
        Use it when you want a quiet author site that can grow into a long-term archive. It is not designed as a marketing landing page or a heavy CMS.
      </p>
    </div>

    <div class="divider-wrap">
      <hr class="section-divider" />
    </div>

    <section class="newsletter-section">
      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: var(--space-12);
    padding-bottom: var(--space-20);
  }
  .prose h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .divider-wrap {
    margin: var(--space-12) 0 var(--space-8) 0;
  }
  .section-divider {
    border: 0;
    border-top: 1px solid var(--border-muted);
  }
</style>
