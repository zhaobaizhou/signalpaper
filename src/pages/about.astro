---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE } from '../config/site';
---

<BaseLayout
  title="About"
  description={`${SITE.name} is a content-first Astro theme for author sites, project archives, and bilingual publishing.`}
>
  <Header />

  <main id="main-content" role="main" class="container fade-in">
    <div class="prose">
      <h1>About SignalPaper</h1>
      <p>
        SignalPaper is a content-first Astro theme for authors, independent creators, and small teams who want a durable home for writing and projects.
      </p>
      <p>
        The default site includes posts, projects, tags, RSS, Pagefind search, reading progress, related writings, bilingual routes, and safe feature toggles for comments, analytics, and newsletters.
      </p>
      <h2>Who it is for</h2>
      <p>
        Use it when you want a quiet author site that can grow into a long-term archive. It is not designed as a marketing landing page or a heavy CMS.
      </p>
    </div>

    <div class="divider-wrap">
      <hr class="section-divider" />
    </div>

    <section class="newsletter-section">
      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: var(--space-12);
    padding-bottom: var(--space-20);
  }
  .prose h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .divider-wrap {
    margin: var(--space-12) 0 var(--space-8) 0;
  }
  .section-divider {
    border: 0;
    border-top: 1px solid var(--border-muted);
  }
</style>
