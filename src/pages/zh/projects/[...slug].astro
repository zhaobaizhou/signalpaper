---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import { getLang, getLocalePath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ id, data }) => {
    return id.startsWith('zh/') && !data.draft;
  });

  // Sort by featured then year descending
  const sorted = projects.sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    const aYear = a.data.year ?? a.data.pubDatetime.getFullYear();
    const bYear = b.data.year ?? b.data.pubDatetime.getFullYear();
    return bYear - aYear;
  });

  return sorted.map((project, index) => {
    const prevProj = sorted[index - 1] ?? null;
    const nextProj = sorted[index + 1] ?? null;

    return {
      params: { slug: project.id.replace(/^zh\//, '').replace(/\.(md|mdx)$/, '') },
      props: {
        project,
        prev: prevProj ? { title: prevProj.data.title, url: `/zh/projects/${prevProj.id.replace(/^zh\//, '').replace(/\.(md|mdx)$/, '')}` } : null,
        next: nextProj ? { title: nextProj.data.title, url: `/zh/projects/${nextProj.id.replace(/^zh\//, '').replace(/\.(md|mdx)$/, '')}` } : null,
      },
    };
  });
}

const { project, prev, next } = Astro.props;
const { Content } = await render(project);
const lang = getLang(Astro.url);
---

<PostLayout 
  post={project as any} 
  prev={prev} 
  next={next} 
  backUrl={getLocalePath(lang, '/projects')} 
  backLabel="返回项目列表"
>
  <Content />
</PostLayout>
