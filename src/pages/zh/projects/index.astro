---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProjectGrid from '../../../components/ProjectGrid.astro';
import { getProjects } from '../../../lib/content';

const lang = 'zh';
const projects = await getProjects(lang);
---

<BaseLayout title="项目" description="我正在构建或已经构建的项目。">
  <Header />
  <main id="main-content" role="main">
    <div class="page-header container">
      <h1 class="page-title">项目</h1>
      <p class="page-subtitle">共 {projects.length} 个</p>
    </div>
    <ProjectGrid projects={projects} showAll={true} />
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header { padding-top: var(--space-12); padding-bottom: var(--space-6); }
  .page-title { font-family: var(--font-serif); font-size: var(--text-3xl); font-weight: 400; margin-bottom: var(--space-2); }
  .page-subtitle { font-size: var(--text-sm); color: var(--fg-muted); }
</style>
