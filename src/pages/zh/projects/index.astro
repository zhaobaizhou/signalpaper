---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProjectGrid from '../../../components/ProjectGrid.astro';
import { getProjects } from '../../../lib/content';
import { getAlternateLinks } from '../../../lib/discovery';
import { buildCollectionPageSchema, buildBreadcrumbSchema } from '../../../lib/schema';

const lang = 'zh';
const projects = await getProjects(lang);

const groupedProjects = projects.reduce((acc, proj) => {
  const y = proj.data.year ?? proj.data.pubDatetime.getFullYear();
  if (!acc[y]) acc[y] = [];
  acc[y].push(proj);
  return acc;
}, {} as Record<string, typeof projects>);

const sortedYears = Object.keys(groupedProjects).sort((a, b) => Number(b) - Number(a));
const alternateLinks = getAlternateLinks({ en: '/projects', zh: '/zh/projects' });
const schema = [
  buildBreadcrumbSchema([
    { name: 'SignalPaper', path: '/zh/' },
    { name: '项目', path: '/zh/projects' },
  ]),
  buildCollectionPageSchema({
    name: '项目',
    description: '我正在构建或已经构建的项目。',
    path: '/zh/projects',
    items: projects.map((project) => ({
      name: project.data.title,
      path: `/zh/projects/${project.id.replace(/^zh\//, '').replace(/\.(md|mdx)$/, '')}`,
      description: project.data.description,
    })),
  }),
];
---

<BaseLayout title="项目" description="我正在构建或已经构建的项目。" alternateLinks={alternateLinks} schema={schema}>
  <Header />
  <main id="main-content" role="main">
    <div class="page-header container">
      <h1 class="page-title">项目</h1>
      <p class="page-subtitle">共 {projects.length} 个</p>
    </div>
    
    <div class="projects-list">
      {sortedYears.map(year => (
        <section class="year-group">
          <div class="container">
            <h2 class="year-heading">{year}</h2>
          </div>
          <ProjectGrid projects={groupedProjects[year]} showAll={true} showStatus={true} />
        </section>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-12);
    padding-bottom: var(--space-6);
  }
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }
  .page-subtitle {
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }
  .projects-list {
    padding-bottom: var(--space-16);
  }
  .year-heading {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    color: var(--fg);
    margin-bottom: var(--space-6);
    padding-top: var(--space-10);
    border-top: 1px solid var(--border-muted);
  }
  .year-group :global(.projects-section .container) {
    border-top: none;
    padding-top: 0;
  }
  .year-group :global(.projects-section) {
    padding-bottom: var(--space-6);
  }
</style>
