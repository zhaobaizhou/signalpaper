---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { SITE } from '../../config/site';
---

<BaseLayout
  title={`近况 | ${SITE.name}`}
  description={`我当前在推进什么、最近在写什么，以及接下来一段时间会关注什么。`}
>
  <Header />

  <main id="main-content" role="main" class="container fade-in">
    <div class="prose">
      <h1>我的近况</h1>
      <p>
        这是一个 /now 页面，灵感来自于 <a href="https://sive.rs/now" target="_blank" rel="noopener">Derek Sivers</a>。相比于“关于”页面讲述过去，这个页面更专注于<strong>我现在正在做什么</strong>。
      </p>

      <h2>当前在推进什么</h2>
      <p>
        我最近主要在打磨 SignalPaper 这个个人站主题，让它更接近一个真正适合长期使用的作者站：信息结构更清楚，文章页阅读体验更稳定，搜索和内容归档也更成熟。
      </p>
      <p>
        这不是一次性搭好的展示站，而是一个持续迭代的工作台。我更关心的是：它能不能承载真实写作，能不能长期维护，能不能把文章、项目、标签和现在在做的事情串成一个完整的个人站体验。
      </p>

      <h2>最近在写什么 / 调整什么</h2>
      <p>
        最近这段时间，我一边补内容，一边调结构。写作上，重点仍然围绕 AI 工作流、产品判断、写作系统和独立工作中的轻量方法。站点上，则主要在修正首页表达、文章页信息节奏、相关文章与订阅模块的关系，以及中英文页面的一致性。
      </p>
      <p>
        我也在刻意把它从“功能堆叠的 demo”拉回到“真正好用的作者站模板”上。很多调整都不是为了多一个 feature，而是为了让第一次访问的人更快看懂这个站是什么、值得从哪里开始看。
      </p>

      <h2>接下来一段时间关注什么</h2>
      <p>
        接下来我会继续做三类事情：第一，收紧首页和 About 页的表达，让站点叙事更稳定；第二，继续清理实现里的噪音和过时写法，降低维护成本；第三，补更多真实内容，确保主题的每一次调整都来自实际使用，而不是只对着空白模板优化。
      </p>
      <p>
        如果你正在关注这个主题的演进，最值得看的仍然是首页、文章页，以及我接下来会持续更新的项目记录。
      </p>
      <p>
        <em>最后更新于：2026 年 5 月</em>
      </p>
    </div>

    <div class="divider-wrap">
      <hr class="section-divider" />
    </div>

    <section class="newsletter-section">
      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: var(--space-12);
    padding-bottom: var(--space-20);
  }
  .prose h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .prose h2 {
    margin-top: var(--space-10);
  }
  .divider-wrap {
    margin: var(--space-12) 0 var(--space-8) 0;
  }
  .section-divider {
    border: 0;
    border-top: 1px solid var(--border-muted);
  }
</style>
