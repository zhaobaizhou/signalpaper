---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
---

<BaseLayout
  title="近况"
  description={`SignalPaper 主题 demo 的当前状态与使用说明。`}
>
  <Header />

  <main id="main-content" role="main" class="container fade-in">
    <div class="prose">
      <h1>Now</h1>
      <p>
        这个页面展示了 SignalPaper 站点里的 <a href="https://sive.rs/now" target="_blank" rel="noopener">/now 页面</a>可以如何使用。正式发布时，你可以把它替换成作者或项目当前关注事项的简短快照。
      </p>

      <h2>当前 demo 展示重点</h2>
      <p>
        这套默认内容主要展示主题的核心体验：
      </p>
      <ul>
        <li><strong>文章归档</strong>：分页文章、标签、阅读信息和相关文章。</li>
        <li><strong>项目归档</strong>：带状态、年份、摘要和详情页的项目内容。</li>
        <li><strong>双语发布</strong>：英文位于根路径，中文位于 <code>/zh</code>。</li>
        <li><strong>站内搜索</strong>：由 Pagefind 驱动，覆盖文章和项目。</li>
        <li><strong>长文阅读</strong>：目录、阅读进度、图片放大和代码复制。</li>
      </ul>
      <h2>使用前需要替换</h2>
      <ul>
        <li>设置生产环境 URL，用于 canonical、RSS、sitemap 和社交卡片。</li>
        <li>替换作者、社交、订阅、评论和统计配置。</li>
        <li>查看 <a href="/docs">文档</a>，保留需要的 demo 页面，删除不适合你站点的内容。</li>
      </ul>
      <p>
        <em>最后更新于：2026 年 5 月</em>
      </p>
    </div>

    <div class="divider-wrap">
      <hr class="section-divider" />
    </div>

    <section class="newsletter-section">
      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: var(--space-12);
    padding-bottom: var(--space-20);
  }
  .prose h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .prose h2 {
    margin-top: var(--space-10);
  }
  .divider-wrap {
    margin: var(--space-12) 0 var(--space-8) 0;
  }
  .section-divider {
    border: 0;
    border-top: 1px solid var(--border-muted);
  }
</style>
