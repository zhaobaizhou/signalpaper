---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostList from '../../../components/PostList.astro';
import { getPosts, getProjects } from '../../../lib/content';

export async function getStaticPaths() {
  const [posts, projects] = await Promise.all([
    getPosts('zh'),
    getProjects('zh'),
  ]);
  const tagSet = new Set<string>();
  for (const item of [...posts, ...projects]) {
    for (const tag of item.data.tags ?? []) tagSet.add(tag);
  }
  return Array.from(tagSet).map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allPosts = await getPosts('zh');
const taggedPosts = allPosts.filter(p => p.data.tags?.includes(tag));
---

<BaseLayout title={`标签：${tag}`} description={`标签"${tag}"下的全部文章`}>
  <Header />
  <main id="main-content" role="main">
    <div class="page-header container">
      <nav class="back-nav">
        <a href="/zh/tags">← 全部标签</a>
      </nav>
      <h1 class="page-title">
        <span class="tag-prefix">#</span>{tag}
      </h1>
      <p class="page-subtitle">共 {taggedPosts.length} 篇</p>
    </div>
    <PostList posts={taggedPosts} showAll={true} />
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header { padding-top: var(--space-12); padding-bottom: var(--space-6); }
  .back-nav { margin-bottom: var(--space-6); }
  .back-nav a { font-size: var(--text-sm); color: var(--fg-muted); transition: color var(--transition-fast); }
  .back-nav a:hover { color: var(--accent); }
  .page-title { font-family: var(--font-serif); font-size: var(--text-3xl); font-weight: 400; margin-bottom: var(--space-2); }
  .tag-prefix { color: var(--accent); margin-right: 0.1em; }
  .page-subtitle { font-size: var(--text-sm); color: var(--fg-muted); }
</style>
