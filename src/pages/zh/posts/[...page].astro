---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PostList from '../../../components/PostList.astro';
import { getPosts } from '../../../lib/content';
import type { GetStaticPaths } from 'astro';
import { getAlternateLinks } from '../../../lib/discovery';
import { buildCollectionPageSchema, buildBreadcrumbSchema } from '../../../lib/schema';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPosts('zh');
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;
const pageTitle = isFirstPage ? '写作' : `写作 — 第 ${page.currentPage} 页`;
const pageDescription = isFirstPage
  ? '所有文章 — 关于 AI 工作流、产品判断力与独立工作的记录。'
  : `文章归档第 ${page.currentPage} 页 — 关于 AI 工作流、产品判断力与独立工作的记录。`;
const path = isFirstPage ? '/zh/posts' : `/zh/posts/${page.currentPage}`;
const alternateLinks = getAlternateLinks({
  en: isFirstPage ? '/posts' : `/posts/${page.currentPage}`,
  zh: path,
});
const schema = [
  buildBreadcrumbSchema([
    { name: 'SignalPaper', path: '/zh/' },
    { name: '写作', path },
  ]),
  buildCollectionPageSchema({
    name: pageTitle,
    description: pageDescription,
    path,
    items: page.data.map((post: any) => ({
      name: post.data.title,
      path: `/zh/posts/${post.id.replace(/^zh\//, '').replace(/\.(md|mdx)$/, '')}`,
      description: post.data.description,
    })),
  }),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  alternateLinks={alternateLinks}
  schema={schema}
>
  <Header />
  <main id="main-content" role="main">
    <div class="page-header container">
      <h1 class="page-title">写作</h1>
      <p class="page-subtitle">共 {page.total} 篇文章</p>
    </div>
    <PostList posts={page.data} showAll={true} />
    
    {(page.url.prev || page.url.next) && (
      <nav class="pagination container" aria-label="Pagination">
        {page.url.prev ? <a href={page.url.prev} class="pagination-link">&larr; 上一页</a> : <span></span>}
        <span class="pagination-info">第 {page.currentPage} 页 / 共 {page.lastPage} 页</span>
        {page.url.next ? <a href={page.url.next} class="pagination-link">下一页 &rarr;</a> : <span></span>}
      </nav>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header { padding-top: var(--space-12); padding-bottom: var(--space-6); }
  .page-title { font-family: var(--font-serif); font-size: var(--text-3xl); font-weight: 400; margin-bottom: var(--space-2); }
  .page-subtitle {
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }
  .pagination-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .pagination-link:hover {
    color: var(--accent);
  }
  .pagination-info {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--fg-muted);
  }
</style>
