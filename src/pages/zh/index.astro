---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import PostList from '../../components/PostList.astro';
import TagCloud from '../../components/TagCloud.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getPosts, getProjects, getTagsWithCount } from '../../lib/content';
import { getAlternateLinks } from '../../lib/discovery';
import { buildCollectionPageSchema } from '../../lib/schema';

const lang = 'zh';
const posts = await getPosts(lang);
const projects = await getProjects(lang);
const tags = await getTagsWithCount(lang);

const homePosts = posts.slice(0, 5);
const homeProjects = projects.slice(0, 2);
const homeTags = tags.slice(0, 20);
const alternateLinks = getAlternateLinks({ en: '/', zh: '/zh/' });
const schema = buildCollectionPageSchema({
  name: 'SignalPaper 中文首页',
  description: '一个内容优先的 Astro 作者站主题，支持写作、项目、标签、搜索和双语发布。',
  path: '/zh/',
  items: [
    ...homePosts.map((post) => ({
      name: post.data.title,
      path: `/zh/posts/${post.id.replace(/^zh\//, '').replace(/\.(md|mdx)$/, '')}`,
      description: post.data.description,
    })),
    ...homeProjects.map((project) => ({
      name: project.data.title,
      path: `/zh/projects/${project.id.replace(/^zh\//, '').replace(/\.(md|mdx)$/, '')}`,
      description: project.data.description,
    })),
  ],
});
---

<BaseLayout
  title={undefined}
  description="一个内容优先的 Astro 作者站主题，支持写作、项目、标签、搜索和双语发布。"
  alternateLinks={alternateLinks}
  schema={schema}
>
  <Header />
  <main id="main-content" role="main">
    <Hero />
    <TagCloud tags={homeTags} />
    <PostList posts={homePosts} />
    <ProjectGrid projects={homeProjects} />
    
    <div class="container">
      <hr class="section-divider" />
    </div>

    <section class="container">
      <Newsletter />
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  main {
    padding-bottom: 0;
  }
  .section-divider {
    border: 0;
    border-top: 1px solid var(--border-muted);
    margin: var(--space-8) 0;
  }
</style>
