---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { SITE } from '../../config/site';
---

<BaseLayout
  title="关于"
  description={`${SITE.name} 是一个为创造者与长期写作者打造的极简 Astro 主题。`}
>
  <Header />

  <main id="main-content" role="main" class="container fade-in">
    <div class="prose">
      <h1>关于 SignalPaper</h1>
      <p>
        SignalPaper 是一个为创造者与长期写作者打造的极简 Astro 主题，适合搭建长期写作与项目归档站。
      </p>
      <p>
        默认站点围绕三个方向展开：中英文双语独立优化、为长文阅读而设计，以及面向 AI 时代的 SEO 与 GEO。
      </p>
      <p>
        使用前可以先查看 <a href="/features">功能概览</a>、<a href="/docs">文档</a> 和 <a href="/faq">FAQ</a>。
      </p>
      <h2>适合谁</h2>
      <p>
        如果你想要一个安静、可长期维护的作者站，而不是营销落地页或复杂 CMS，SignalPaper 会更适合。
      </p>
    </div>

    <div class="divider-wrap">
      <hr class="section-divider" />
    </div>

    <section class="newsletter-section">
      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: var(--space-12);
    padding-bottom: var(--space-20);
  }
  .prose h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .divider-wrap {
    margin: var(--space-12) 0 var(--space-8) 0;
  }
  .section-divider {
    border: 0;
    border-top: 1px solid var(--border-muted);
  }
</style>
