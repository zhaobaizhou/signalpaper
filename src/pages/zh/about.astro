---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import { SITE } from '../../config/site';
---

<BaseLayout
  title="关于"
  description={`${SITE.name} 是一个内容优先的 Astro 作者站主题，适合写作、项目归档和双语发布。`}
>
  <Header />

  <main id="main-content" role="main" class="container fade-in">
    <div class="prose">
      <h1>关于 SignalPaper</h1>
      <p>
        SignalPaper 是一个内容优先的 Astro 作者站主题，适合作者、独立创作者和小团队搭建长期写作与项目归档站。
      </p>
      <p>
        默认站点包含文章、项目、标签、RSS、Pagefind 搜索、阅读进度、相关文章、双语路由，以及评论、统计和订阅等安全关闭的功能开关。
      </p>
      <h2>适合谁</h2>
      <p>
        如果你想要一个安静、可长期维护的作者站，而不是营销落地页或复杂 CMS，SignalPaper 会更适合。
      </p>
    </div>

    <div class="divider-wrap">
      <hr class="section-divider" />
    </div>

    <section class="newsletter-section">
      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: var(--space-12);
    padding-bottom: var(--space-20);
  }
  .prose h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .divider-wrap {
    margin: var(--space-12) 0 var(--space-8) 0;
  }
  .section-divider {
    border: 0;
    border-top: 1px solid var(--border-muted);
  }
</style>
