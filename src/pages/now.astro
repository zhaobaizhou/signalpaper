---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { SITE } from '../config/site';
---

<BaseLayout
  title="Now"
  description={`Current status and roadmap notes for the ${SITE.name} theme demo.`}
>
  <Header />

  <main id="main-content" role="main" class="container fade-in">
    <div class="prose">
      <h1>Now</h1>
      <p>
        This page demonstrates how a <a href="https://sive.rs/now" target="_blank" rel="noopener">/now page</a> can work inside a SignalPaper site. Replace it with a short, current snapshot of what the author or project is focused on.
      </p>

      <h2>Current demo focus</h2>
      <p>
        This demo highlights the core theme experience:
      </p>
      <ul>
        <li><strong>Writing archive</strong>: Paginated posts, tags, reading metadata, and related writings.</li>
        <li><strong>Project archive</strong>: Project entries with status, year, summaries, and detail pages.</li>
        <li><strong>Bilingual publishing</strong>: English routes at the root and Chinese routes under <code>/zh</code>.</li>
        <li><strong>Search</strong>: Pagefind-powered search for posts and projects.</li>
        <li><strong>Long-form reading</strong>: Table of contents, reading progress, image zoom, and code copy controls.</li>
      </ul>

      <h2>Before using it</h2>
      <p>
        Replace the demo content, update <code>src/config/site.ts</code>, and enable only the integrations you actually use.
      </p>
      <ul>
        <li>Set your production URL for canonical links, RSS, sitemap, and social cards.</li>
        <li>Replace author, social, newsletter, comments, and analytics settings.</li>
        <li>Keep the demo pages you need and remove anything that does not fit your site.</li>
      </ul>
      <p>
        <em>Last updated: May 2026</em>
      </p>
    </div>

    <div class="divider-wrap">
      <hr class="section-divider" />
    </div>

    <section class="newsletter-section">
      <Newsletter />
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: var(--space-12);
    padding-bottom: var(--space-20);
  }
  .prose h1 {
    font-size: var(--text-3xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }
  .prose h2 {
    margin-top: var(--space-10);
  }
  .divider-wrap {
    margin: var(--space-12) 0 var(--space-8) 0;
  }
  .section-divider {
    border: 0;
    border-top: 1px solid var(--border-muted);
  }
</style>
