---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getAlternateLinks } from '../lib/discovery';
import { buildBreadcrumbSchema } from '../lib/schema';

const alternateLinks = getAlternateLinks({ en: '/features', zh: '/zh/features' });
const schema = buildBreadcrumbSchema([
  { name: 'SignalPaper', path: '/' },
  { name: 'Features', path: '/features' },
]);
---

<DocsLayout
  title="Features"
  description="SignalPaper is a content-first Astro theme for author sites, project archives, bilingual publishing, search, and long-form reading."
  alternateLinks={alternateLinks}
  schema={schema}
>
  <h2>Core publishing surfaces</h2>
  <p>SignalPaper ships with posts, projects, tags, about, now, RSS, sitemap, and search. The default structure is intentionally small so the archive can grow without becoming hard to maintain.</p>

  <h2>Long-form reading</h2>
  <p>Article pages include reading progress, table of contents, reading metadata, related writings, image zoom, and code copy controls.</p>

  <h2>Bilingual publishing</h2>
  <p>English routes live at the root. Chinese routes live under <code>/zh</code>. Each language has its own content files, metadata, tags, and generated pages.</p>

  <h2>Search and discovery</h2>
  <p>Search is powered by Pagefind during the production build. Tag pages, archives, related posts, RSS, and <code>llms.txt</code> provide additional discovery paths.</p>

  <h2>Safe defaults</h2>
  <p>Comments, analytics, and newsletter integrations are disabled by default. Enable only the services you configure.</p>
</DocsLayout>
