---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostList from '../../components/PostList.astro';
import { getPosts } from '../../lib/content';
import type { GetStaticPaths } from 'astro';
import { getAlternateLinks } from '../../lib/discovery';
import { buildCollectionPageSchema, buildBreadcrumbSchema } from '../../lib/schema';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPosts('en');
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;
const pageTitle = isFirstPage ? 'Writings' : `Writings — Page ${page.currentPage}`;
const pageDescription = isFirstPage
  ? 'All writings — articles on AI workflows, product judgment, and independent work.'
  : `Writings archive page ${page.currentPage} — articles on AI workflows, product judgment, and independent work.`;
const path = isFirstPage ? '/posts' : `/posts/${page.currentPage}`;
const alternateLinks = getAlternateLinks({
  en: path,
  zh: isFirstPage ? '/zh/posts' : `/zh/posts/${page.currentPage}`,
});
const schema = [
  buildBreadcrumbSchema([
    { name: 'SignalPaper', path: '/' },
    { name: 'Writings', path },
  ]),
  buildCollectionPageSchema({
    name: pageTitle,
    description: pageDescription,
    path,
    items: page.data.map((post: any) => ({
      name: post.data.title,
      path: `/posts/${post.id.replace(/^en\//, '').replace(/\.(md|mdx)$/, '')}`,
      description: post.data.description,
    })),
  }),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  alternateLinks={alternateLinks}
  schema={schema}
>
  <Header />
  <main id="main-content" role="main">
    <div class="page-header container">
      <h1 class="page-title">Writings</h1>
      <p class="page-subtitle">{page.total} articles</p>
    </div>
    <PostList posts={page.data} showAll={true} />
    
    {(page.url.prev || page.url.next) && (
      <nav class="pagination container" aria-label="Pagination">
        {page.url.prev ? <a href={page.url.prev} class="pagination-link">&larr; Newer</a> : <span></span>}
        <span class="pagination-info">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next ? <a href={page.url.next} class="pagination-link">Older &rarr;</a> : <span></span>}
      </nav>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-12);
    padding-bottom: var(--space-6);
  }
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }
  .page-subtitle {
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }
  .pagination-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .pagination-link:hover {
    color: var(--accent);
  }
  .pagination-info {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--fg-muted);
  }
</style>
