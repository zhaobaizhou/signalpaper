---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostList from '../../components/PostList.astro';
import { getPosts } from '../../lib/content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPosts('en');
  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout
  title="Writings"
  description="All writings — articles on AI workflows, product judgment, and independent work."
>
  <Header />
  <main id="main-content" role="main">
    <div class="page-header container">
      <h1 class="page-title">Writings</h1>
      <p class="page-subtitle">{page.total} articles</p>
    </div>
    <PostList posts={page.data} showAll={true} />
    
    {(page.url.prev || page.url.next) && (
      <nav class="pagination container" aria-label="Pagination">
        {page.url.prev ? <a href={page.url.prev} class="pagination-link">&larr; Newer</a> : <span></span>}
        <span class="pagination-info">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next ? <a href={page.url.next} class="pagination-link">Older &rarr;</a> : <span></span>}
      </nav>
    )}
  </main>
  <Footer />
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-12);
    padding-bottom: var(--space-6);
  }
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }
  .page-subtitle {
    font-size: var(--text-sm);
    color: var(--fg-muted);
  }
  .pagination {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }
  .pagination-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .pagination-link:hover {
    color: var(--accent);
  }
  .pagination-info {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--fg-muted);
  }
</style>
