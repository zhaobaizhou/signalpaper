---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getRelatedPosts, getSlug } from '../../lib/content';
import { getContentAlternateMap } from '../../lib/discovery';

export async function getStaticPaths() {
  const [posts, alternates] = await Promise.all([
    getCollection('posts', ({ id, data }) => {
      return id.startsWith('en/') && !data.draft;
    }),
    getContentAlternateMap(),
  ]);

  // Sort: featured first, then by date
  const sorted = posts.sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf();
  });

  return Promise.all(sorted.map(async (post, index) => {
    const prevPost = sorted[index - 1] ?? null;
    const nextPost = sorted[index + 1] ?? null;

    return {
      params: { slug: getSlug(post.id) },
      props: {
        post,
        prev: prevPost ? { title: prevPost.data.title, url: `/posts/${getSlug(prevPost.id)}` } : null,
        next: nextPost ? { title: nextPost.data.title, url: `/posts/${getSlug(nextPost.id)}` } : null,
        relatedPosts: await getRelatedPosts(post, 'en'),
        alternates: alternates.get(`post:${getSlug(post.id)}`),
      },
    };
  }));
}

const { post, prev, next, relatedPosts, alternates } = Astro.props;
const { Content, headings } = await render(post);
---

<PostLayout post={post} prev={prev} next={next} relatedPosts={relatedPosts} headings={headings} alternates={alternates}>
  <Content />
</PostLayout>
