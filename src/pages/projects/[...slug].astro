---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getLang, getLocalePath } from '../../i18n/utils';
import { getContentAlternateMap } from '../../lib/discovery';

export async function getStaticPaths() {
  const [projects, alternates] = await Promise.all([
    getCollection('projects', ({ id, data }) => {
      return id.startsWith('en/') && !data.draft;
    }),
    getContentAlternateMap(),
  ]);

  // Sort by featured then year descending
  const sorted = projects.sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    const aYear = a.data.year ?? a.data.pubDatetime.getFullYear();
    const bYear = b.data.year ?? b.data.pubDatetime.getFullYear();
    return bYear - aYear;
  });

  return sorted.map((project, index) => {
    const prevProj = sorted[index - 1] ?? null;
    const nextProj = sorted[index + 1] ?? null;

    return {
      params: { slug: project.id.replace(/^en\//, '').replace(/\.(md|mdx)$/, '') },
      props: {
        project,
        prev: prevProj ? { title: prevProj.data.title, url: `/projects/${prevProj.id.replace(/^en\//, '').replace(/\.(md|mdx)$/, '')}` } : null,
        next: nextProj ? { title: nextProj.data.title, url: `/projects/${nextProj.id.replace(/^en\//, '').replace(/\.(md|mdx)$/, '')}` } : null,
        alternates: alternates.get(`project:${project.id.replace(/^en\//, '').replace(/\.(md|mdx)$/, '')}`),
      },
    };
  });
}

const { project, prev, next, alternates } = Astro.props;
const { Content, headings } = await render(project);
const lang = getLang(Astro.url);
---

<PostLayout 
  post={project as any} 
  prev={prev} 
  next={next} 
  backUrl={getLocalePath(lang, '/projects')} 
  backLabel="Back to projects"
  headings={headings}
  alternates={alternates}
>
  <Content />
</PostLayout>
