---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostList from '../../components/PostList.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import { getPosts, getProjects } from '../../lib/content';

export async function getStaticPaths() {
  // Collect all tags from EN posts + projects
  const [posts, projects] = await Promise.all([
    getPosts('en'),
    getProjects('en'),
  ]);
  const tagSet = new Set<string>();
  for (const item of [...posts, ...projects]) {
    for (const tag of item.data.tags ?? []) tagSet.add(tag);
  }
  return Array.from(tagSet).map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const allPosts = await getPosts('en');
const allProjects = await getProjects('en');
const taggedPosts = allPosts.filter(p => p.data.tags?.includes(tag));
const taggedProjects = allProjects.filter(p => p.data.tags?.includes(tag));
const totalCount = taggedPosts.length + taggedProjects.length;
---

<BaseLayout
  title={`Tag: ${tag}`}
  description={`Items tagged "${tag}"`}
>
  <Header />
  <main id="main-content" role="main">
    <div class="page-header container">

      <h1 class="page-title">
        <span class="tag-prefix">#</span>{tag}
      </h1>
      <p class="page-subtitle">{totalCount} item{totalCount !== 1 ? 's' : ''}</p>
    </div>
    {taggedPosts.length > 0 && <PostList posts={taggedPosts} showAll={true} title="Writings" />}
    {taggedProjects.length > 0 && (
      <div style={taggedPosts.length > 0 ? "margin-top: var(--space-12);" : ""}>
        <ProjectGrid projects={taggedProjects} showAll={true} title="Projects" />
      </div>
    )}
  </main>
  <Footer />

  <aside class="post-fab" id="post-fab" aria-label="Page tools">
    <button class="fab-btn" id="fab-top" aria-label="Back to top">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
    </button>
  </aside>

  <script>
    const fab = document.getElementById('post-fab');
    const fabTop = document.getElementById('fab-top');
    if (fab) {
      window.addEventListener('scroll', () => {
        fab.classList.toggle('fab-visible', window.scrollY > 300);
      }, { passive: true });
    }
    fabTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  </script>
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-12);
    padding-bottom: var(--space-6);
  }
  .page-title {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: 400;
    margin-bottom: var(--space-2);
  }
  .tag-prefix { color: var(--accent); margin-right: 0.1em; }
  .page-subtitle { font-size: var(--text-sm); color: var(--fg-muted); }

  /* Floating back to top button */
  .post-fab {
    position: fixed;
    right: max(16px, calc((100vw - var(--content-width)) / 2 - 68px));
    bottom: 48px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 50;
    opacity: 0;
    transform: translateX(6px);
    transition: opacity 200ms ease, transform 200ms ease;
    pointer-events: none;
  }
  .post-fab.fab-visible {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
  .fab-btn {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .fab-btn:hover {
    background: var(--bg-alt);
    border-color: var(--accent);
    color: var(--accent);
  }
  @media (max-width: 900px) {
    .post-fab { right: 12px; bottom: 24px; }
  }
</style>
