---
import { SITE } from '../config/site';

const isDev = import.meta.env.DEV;
const { enabled, provider, google } = SITE.analytics;
const shouldRender = enabled && !isDev && provider === 'google' && google.measurementId;
---

{shouldRender && (
  <>
    <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${google.measurementId}`}></script>
    <script is:inline define:vars={{ measurementId: google.measurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', measurementId);
    </script>
  </>
)}
