---
import { SITE } from '../config/site';
import { getLang, useTranslations } from '../i18n/utils';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const bio = SITE.author.bio[lang];
const bioLines = bio.split('\n\n');
---

<section class="hero" aria-label="Introduction">
  <div class="container">
    <h1 class="sr-only">
      {lang === 'zh' ? `你好，我是${SITE.author.name}。` : SITE.author.name}
    </h1>

    <div class="hero-bio">
      {bioLines.map((line, i) => (
        <p class={i === 0 ? 'hero-bio-primary' : 'hero-bio-secondary'}>{line}</p>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
  }

  .hero-bio {
    max-width: 520px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-bio-primary {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    line-height: 1.7;
  }

  .hero-bio-secondary {
    font-size: var(--text-base);
    color: var(--fg-muted);
    line-height: 1.7;
  }


</style>
