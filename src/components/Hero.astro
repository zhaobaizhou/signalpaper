---
import { SITE } from '../config/site';
import { getLang } from '../i18n/utils';

const lang = getLang(Astro.url);
const heroContent = {
  en: [
    `SignalPaper is <strong>a minimalist Astro theme for builders, writers, and AI-native personal sites</strong>.`,
    `Build, Clarity, Publish. Explore the default structure through <a href="/posts">writings</a>, <a href="/projects">projects</a>, <a href="/tags">tag navigation</a>, <a href="/now">Now</a>, and <a href="/about">About</a> pages you can replace with your own content.`,
  ],
  zh: [
    `SignalPaper 是一个<strong>为创造者与长期写作者打造的极简 Astro 主题</strong>。`,
    `让你的作品、文章与项目清晰可见。你可以通过 <a href="/zh/posts">文章</a>、<a href="/zh/projects">项目</a>、<a href="/zh/tags">标签导航</a>、<a href="/zh/now">Now</a> 和 <a href="/zh/about">About</a> 这些默认页面结构来开始替换自己的内容。`,
  ],
} as const;
---

<section class="hero" aria-label="Introduction">
  <div class="container">
    <h1 class="sr-only">
      {SITE.name}
    </h1>

    <div class="hero-bio">
      {heroContent[lang].map((line, i) => (
        <p class={i === 0 ? 'hero-bio-primary' : 'hero-bio-secondary'} set:html={line}></p>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-6);
    padding-bottom: var(--space-10);
  }

  .hero-bio {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-bio-primary {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    line-height: 1.7;
  }

  .hero-bio-secondary {
    font-size: var(--text-base);
    color: var(--fg-muted);
    line-height: 1.7;
  }

  .hero-bio :global(a) {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--border-muted);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--transition-fast), color var(--transition-fast);
  }

  .hero-bio :global(a:hover) {
    color: var(--fg);
    text-decoration-color: var(--fg);
  }

</style>
