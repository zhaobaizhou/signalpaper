---
import { SITE } from '../config/site';
import { getLang } from '../i18n/utils';

const lang = getLang(Astro.url);
const heroContent = {
  en: [
    `SignalPaper is a content-first Astro theme for authors who want a durable home for <a href="/posts">writings</a>, <a href="/projects">projects</a>, tags, search, and bilingual publishing.`,
    `Use this demo to explore the default structure: long-form reading, project archives, <a href="/tags">tag navigation</a>, <a href="/now">Now</a>, and <a href="/about">About</a> pages that can be replaced with your own content.`,
  ],
  zh: [
    `SignalPaper 是一个内容优先的 Astro 作者站主题，用来承载<a href="/zh/posts">文章</a>、<a href="/zh/projects">项目</a>、标签、搜索和双语发布。`,
    `这个 demo 展示了默认站点结构：长文阅读、项目归档、<a href="/zh/tags">标签导航</a>、<a href="/zh/now">Now</a> 和 <a href="/zh/about">About</a> 页面都可以替换成你自己的内容。`,
  ],
} as const;
---

<section class="hero" aria-label="Introduction">
  <div class="container">
    <h1 class="sr-only">
      {SITE.name}
    </h1>

    <div class="hero-bio">
      {heroContent[lang].map((line, i) => (
        <p class={i === 0 ? 'hero-bio-primary' : 'hero-bio-secondary'} set:html={line}></p>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-6);
    padding-bottom: var(--space-10);
  }

  .hero-bio {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-bio-primary {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    line-height: 1.7;
  }

  .hero-bio-secondary {
    font-size: var(--text-base);
    color: var(--fg-muted);
    line-height: 1.7;
  }

  .hero-bio :global(a) {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--border-muted);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--transition-fast), color var(--transition-fast);
  }

  .hero-bio :global(a:hover) {
    color: var(--fg);
    text-decoration-color: var(--fg);
  }

</style>
