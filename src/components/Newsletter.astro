---
import { getLang, useTranslations } from '../i18n/utils';
import { SITE } from '../config/site';

const lang = getLang(Astro.url);
const t = useTranslations(lang);

const isEnabled = SITE.newsletter.enabled && SITE.newsletter.actionUrl;
const actionUrl = SITE.newsletter.actionUrl;
---

{isEnabled && (
  <aside class="newsletter-wrapper">
    <div class="newsletter-content">
      <h2 class="newsletter-title">{t('newsletter.title')}</h2>
      <p class="newsletter-description">
        {lang === 'zh' ? (
          <Fragment>
            通过邮件订阅更新，或使用 <a href={SITE.social.rss} target="_blank">RSS</a> 关注新的文章和项目。
          </Fragment>
        ) : (
          <Fragment>
            Subscribe for updates, or use <a href={SITE.social.rss} target="_blank">RSS</a> to follow new writings and projects.
          </Fragment>
        )}
      </p>
    </div>
    <form
      action={actionUrl}
      method="post"
      target="_blank"
      class="newsletter-form"
      onsubmit={`window.open('${actionUrl}', 'popupwindow')`}
    >
      <input
        type="email"
        name="email"
        placeholder={t('newsletter.placeholder')}
        required
        aria-label={t('newsletter.placeholder')}
      />
      <!-- This is used by Buttondown to prevent spam -->
      <input type="hidden" value="1" name="embed" />
      <button type="submit">{t('newsletter.button')}</button>
    </form>
  </aside>
)}

<style>
  .newsletter-wrapper {
    margin-top: var(--space-12);
    margin-bottom: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .newsletter-title {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin: 0;
    margin-bottom: var(--space-3);
  }

  .newsletter-description {
    font-size: var(--text-base);
    color: var(--fg-muted);
    margin: 0;
    line-height: 1.6;
  }

  .newsletter-description a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--border-muted);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--transition-fast);
  }

  .newsletter-description a:hover {
    text-decoration-color: var(--fg);
  }

  .newsletter-form {
    display: flex;
    gap: var(--space-4);
    align-items: flex-end;
    max-width: 100%;
    margin-top: var(--space-5);
  }

  .newsletter-form input[type="email"] {
    flex: 1;
    min-width: 0;
    padding: var(--space-4) var(--space-1);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    color: var(--fg);
    font-size: var(--text-lg);
    line-height: 1.5;
    transition: border-color var(--transition-fast);
  }

  .newsletter-form input[type="email"]:focus {
    outline: none;
    border-bottom-color: var(--fg);
  }

  .newsletter-form input[type="email"]::placeholder {
    color: var(--fg-subtle);
  }

  .newsletter-form button {
    padding: 0 var(--space-10);
    background-color: var(--card-bg);
    color: var(--fg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast);
    white-space: nowrap;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .newsletter-form button:hover {
    background-color: var(--card-hover);
    border-color: var(--fg-muted);
  }

  .newsletter-form button:active {
    transform: scale(0.98);
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-5);
    }
    .newsletter-form button {
      width: 100%;
    }
  }
</style>
