---
import { getLang, useTranslations } from '../i18n/utils';
import { SITE } from '../config/site';

const lang = getLang(Astro.url);
const t = useTranslations(lang);

const isEnabled = SITE.newsletter.enabled;
const actionUrl = SITE.newsletter.actionUrl;
---

{isEnabled && (
  <aside class="newsletter-wrapper">
    <div class="newsletter-content">
      <h3 class="newsletter-title">{t('newsletter.title')}</h3>
      <p class="newsletter-description">
        {lang === 'zh' ? (
          <Fragment>
            通过邮件、<a href={SITE.social.rss} target="_blank">RSS</a>、<a href={SITE.social.x} target="_blank">Twitter</a>、<a href={SITE.social.github} target="_blank">GitHub</a> 等方式<a href="/zh/about">关注我的更新</a>。
          </Fragment>
        ) : (
          <Fragment>
            Follow me via <a href={SITE.social.email}>Email</a>, <a href={SITE.social.rss} target="_blank">RSS</a>, <a href={SITE.social.x} target="_blank">Twitter</a>, <a href={SITE.social.github} target="_blank">GitHub</a> and <a href="/about">other options</a>.
          </Fragment>
        )}
      </p>
    </div>
    <form
      action={actionUrl}
      method="post"
      target="_blank"
      class="newsletter-form"
      onsubmit={`window.open('${actionUrl}', 'popupwindow')`}
    >
      <input
        type="email"
        name="email"
        placeholder={t('newsletter.placeholder')}
        required
        aria-label={t('newsletter.placeholder')}
      />
      <!-- This is used by Buttondown to prevent spam -->
      <input type="hidden" value="1" name="embed" />
      <button type="submit">{t('newsletter.button')}</button>
    </form>
  </aside>
)}

<style>
  .newsletter-wrapper {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .newsletter-title {
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--fg);
    margin: 0;
  }

  .newsletter-description {
    font-size: var(--text-base);
    color: var(--fg-muted);
    margin: 0;
    margin-bottom: var(--space-md);
    line-height: 1.5;
  }

  .newsletter-description a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--border-muted);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--transition-fast);
  }

  .newsletter-description a:hover {
    text-decoration-color: var(--fg);
  }

  .newsletter-form {
    display: flex;
    gap: var(--space-md);
    align-items: flex-end;
    max-width: 100%;
  }

  .newsletter-form input[type="email"] {
    flex: 1;
    min-width: 0;
    padding: var(--space-md) var(--space-xs);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
    color: var(--fg);
    font-size: var(--text-lg);
    line-height: 1.5;
    transition: border-color var(--transition-fast);
  }

  .newsletter-form input[type="email"]:focus {
    outline: none;
    border-bottom-color: var(--fg);
  }

  .newsletter-form input[type="email"]::placeholder {
    color: var(--fg-subtle);
  }

  .newsletter-form button {
    padding: 0 var(--space-2xl);
    background-color: var(--fg);
    color: var(--bg);
    border: none;
    border-radius: var(--radius-sm);
    font-size: var(--text-base);
    font-weight: 500;
    cursor: pointer;
    transition:
      transform var(--transition-fast),
      opacity var(--transition-fast);
    white-space: nowrap;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .newsletter-form button:hover {
    opacity: 0.9;
  }

  .newsletter-form button:active {
    transform: scale(0.98);
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-lg);
    }
    .newsletter-form button {
      width: 100%;
    }
  }
</style>
