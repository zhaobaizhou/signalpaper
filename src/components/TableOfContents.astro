---
import { getLang, useTranslations } from '../i18n/utils';

interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const lang = getLang(Astro.url);
const t = useTranslations(lang);

// Filter to H2 and H3 only
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{toc.length > 0 && (
  <nav class="toc-container" aria-label="Table of Contents">
    <h2 class="toc-title">{t('post.toc')}</h2>
    <ul class="toc-list" id="toc-list">
      {toc.map(heading => (
        <li class={`toc-item toc-depth-${heading.depth}`}>
          <a href={`#${heading.slug}`} class="toc-link" data-slug={heading.slug} title={heading.text}>
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            const activeLink = document.querySelector(`.toc-link[data-slug="${id}"]`);
            
            if (activeLink) {
              document.querySelectorAll('.toc-link').forEach(link => link.classList.remove('active'));
              activeLink.classList.add('active');
            }
          }
        });
      },
      // We trigger active state when heading is near the top 15% of viewport
      { rootMargin: '-15% 0px -85% 0px' }
    );

    document.querySelectorAll('.prose h2, .prose h3').forEach((heading) => {
      observer.observe(heading);
    });
  });
</script>

<style>
  .toc-container {
    position: fixed;
    top: 160px;
    right: max(16px, calc((100vw - var(--content-width)) / 2 - 240px));
    width: 220px;
    /* User request 3: Control height */
    max-height: calc(100vh - 200px);
    overflow-y: hidden; /* Hide scrollbar by default */
    /* Default transparent, full opacity on hover */
    opacity: 0.3;
    transition: opacity var(--transition-fast);
    z-index: 40;
  }

  .toc-container:hover {
    opacity: 1;
    overflow-y: auto; /* Show scrollbar on hover */
  }

  .toc-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--fg);
    margin-bottom: var(--space-4);
    letter-spacing: 0.02em;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border);
  }

  .toc-item {
    margin: 0;
  }

  .toc-link {
    display: block;
    padding: 6px 0 6px 16px;
    font-size: var(--text-sm);
    color: var(--fg-muted);
    text-decoration: none;
    line-height: 1.4;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    position: relative;
    margin-left: -1px;
    border-left: 2px solid transparent;
    
    /* User request 2: Truncate long text with ellipsis */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Indent H3 */
  .toc-depth-3 .toc-link {
    padding-left: 28px;
    font-size: 0.85em;
  }

  .toc-link:hover {
    color: var(--fg);
  }

  /* Active state styling */
  .toc-link.active {
    color: var(--fg);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  /* Hide on screens smaller than 1280px */
  @media (max-width: 1280px) {
    .toc-container {
      display: none;
    }
  }

  /* Custom scrollbar */
  .toc-container::-webkit-scrollbar {
    width: 4px;
  }
  .toc-container::-webkit-scrollbar-track {
    background: transparent;
  }
  .toc-container::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }
</style>
