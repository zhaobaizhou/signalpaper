---
import { getLang, useTranslations } from '../i18n/utils';

interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const lang = getLang(Astro.url);
const t = useTranslations(lang);

// Filter to H2 and H3 only
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{toc.length > 0 && (
  <nav class="toc-wrapper" aria-label="Table of Contents">
    <h2 class="toc-title">{t('post.toc')}</h2>
    <div class="toc-container">
      <ul class="toc-list" id="toc-list">
        {toc.map(heading => (
          <li class={`toc-item toc-depth-${heading.depth}`}>
            <a href={`#${heading.slug}`} class="toc-link" data-slug={heading.slug} title={heading.text}>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            const activeLink = document.querySelector(`.toc-link[data-slug="${id}"]`);
            
            if (activeLink) {
              document.querySelectorAll('.toc-link').forEach(link => link.classList.remove('active'));
              activeLink.classList.add('active');
            }
          }
        });
      },
      // We trigger active state when heading is near the top 15% of viewport
      { rootMargin: '-15% 0px -85% 0px' }
    );

    document.querySelectorAll('.prose h2, .prose h3').forEach((heading) => {
      observer.observe(heading);
    });
  });
</script>

<style>
  .toc-wrapper {
    position: fixed;
    top: 140px;
    right: max(16px, calc((100vw - var(--content-width)) / 2 - 240px));
    width: 200px;
    z-index: 40;
    opacity: 0.25;
    transition: opacity var(--transition-slow);
  }

  .toc-wrapper:hover {
    opacity: 1;
  }

  /* Title is outside the scroll container so it never moves */
  .toc-title {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: var(--space-3);
    letter-spacing: 0.05em;
    padding-left: 16px;
  }

  .toc-container {
    /* Height calculation: 100vh - top(140) - floating-tools(~150) - title(~30) */
    max-height: calc(100vh - 320px);
    overflow-y: hidden;
  }

  .toc-wrapper:hover .toc-container {
    overflow-y: auto;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border-left: 1px solid var(--border-muted);
  }

  .toc-item {
    margin: 0;
  }

  .toc-link {
    display: block;
    padding: 4px 0 4px 16px;
    font-size: 13px;
    color: var(--fg-subtle);
    text-decoration: none;
    line-height: 1.5;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    position: relative;
    margin-left: -1px;
    border-left: 2px solid transparent;
    
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .toc-depth-3 .toc-link {
    padding-left: 24px;
    font-size: 12px;
    color: var(--fg-muted);
  }

  .toc-link:hover {
    color: var(--fg);
  }

  .toc-link.active {
    color: var(--fg);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 1280px) {
    .toc-wrapper {
      display: none;
    }
  }

  .toc-container::-webkit-scrollbar {
    width: 3px;
  }
  .toc-container::-webkit-scrollbar-track {
    background: transparent;
  }
  .toc-container::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }
</style>
