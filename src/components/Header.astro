---
import { SITE } from '../config/site';
import { getLang, useTranslations, getAlternatePath, getLocalePath, languages } from '../i18n/utils';
import ThemeToggle from './ThemeToggle.astro';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const alternateLang = lang === 'en' ? 'zh' : 'en';
const alternatePath = getAlternatePath(lang, Astro.url.pathname);
---

<header class="site-header" role="banner">
  <div class="header-inner container">
    <!-- Logo / Brand -->
    <a href={getLocalePath(lang, '/')} class="header-brand" aria-label={SITE.name}>
      <span class="header-logo" aria-hidden="true">SP</span>
      <span class="header-brand-text">
        <span class="header-site-name">{SITE.name}</span>
        <span class="header-tagline">{lang === 'zh' ? '个人创作者生活主题' : SITE.tagline}</span>
      </span>
    </a>

    <!-- Right controls -->
    <nav class="header-controls" aria-label="Site controls">
      <!-- Search trigger -->
      <button
        id="search-toggle"
        class="header-btn"
        aria-label={t('nav.search')}
        aria-expanded="false"
        aria-controls="search-dialog"
      >
        <span class="header-btn-text">{t('nav.search')}</span>
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M10 6.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Zm-.885 3.23a4.5 4.5 0 1 1 .707-.708l2.927 2.927a.5.5 0 0 1-.707.707L9.115 9.73Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
        </svg>
      </button>

      <!-- Language switcher -->
      <a
        href={alternatePath}
        class="header-lang-btn"
        aria-label={`Switch to ${alternateLang === 'zh' ? 'Chinese' : 'English'}`}
        hreflang={alternateLang}
      >
        {languages[alternateLang]}
      </a>

      <!-- Theme toggle -->
      <ThemeToggle />
    </nav>
  </div>
</header>

<!-- Search Dialog -->
<div id="search-dialog" class="search-overlay" role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div class="search-box">
    <div class="search-input-wrap">
      <svg width="16" height="16" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="search-icon">
        <path d="M10 6.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Zm-.885 3.23a4.5 4.5 0 1 1 .707-.708l2.927 2.927a.5.5 0 0 1-.707.707L9.115 9.73Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder={t('search.placeholder')}
        autocomplete="off"
        spellcheck="false"
      />
      <button id="search-close" aria-label="Close search">
        <svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M12.854 2.854a.5.5 0 0 0-.708-.708L7.5 6.793 2.854 2.146a.5.5 0 0 0-.708.708L6.793 7.5l-4.647 4.646a.5.5 0 0 0 .708.708L7.5 8.207l4.646 4.647a.5.5 0 0 0 .708-.708L8.207 7.5l4.647-4.646Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
    <div id="search-results" class="search-results" role="listbox">
      <p class="search-hint">{t('search.placeholder')}</p>
    </div>
  </div>
</div>

<script>
  // Search toggle
  const toggle = document.getElementById('search-toggle');
  const dialog = document.getElementById('search-dialog');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-input') as HTMLInputElement | null;

  function openSearch() {
    if (!dialog || !toggle) return;
    dialog.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    setTimeout(() => input?.focus(), 50);
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    if (!dialog || !toggle) return;
    dialog.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openSearch);
  closeBtn?.addEventListener('click', closeSearch);

  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) closeSearch();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
  });

  // Simple client-side search using fetch from /search-index.json
  let searchIndex: Array<{ title: string; url: string; description: string; tags: string[] }> = [];

  async function loadIndex() {
    if (searchIndex.length > 0) return;
    try {
      const res = await fetch('/search-index.json');
      if (res.ok) searchIndex = await res.json();
    } catch {}
  }

  const resultsEl = document.getElementById('search-results');

  input?.addEventListener('input', async () => {
    const query = input.value.trim().toLowerCase();
    if (!resultsEl) return;

    if (!query) {
      resultsEl.innerHTML = `<p class="search-hint">${input.placeholder}</p>`;
      return;
    }

    await loadIndex();

    const matches = searchIndex.filter(item =>
      item.title.toLowerCase().includes(query) ||
      item.description.toLowerCase().includes(query) ||
      item.tags?.some(t => t.toLowerCase().includes(query))
    ).slice(0, 8);

    if (matches.length === 0) {
      resultsEl.innerHTML = `<p class="search-no-results">No results for "<strong>${query}</strong>"</p>`;
      return;
    }

    resultsEl.innerHTML = matches
      .map(m => `
        <a href="${m.url}" class="search-result-item" role="option">
          <span class="sr-item-title">${m.title}</span>
          <span class="sr-item-desc">${m.description}</span>
        </a>
      `)
      .join('');
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border-muted);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background-color: color-mix(in srgb, var(--bg) 85%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    gap: var(--space-4);
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--fg);
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
  }

  .header-brand:hover {
    opacity: 0.8;
  }

  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: var(--fg);
    color: var(--bg);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    font-family: var(--font-mono);
  }

  .header-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .header-site-name {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .header-tagline {
    font-size: 0.68rem;
    color: var(--fg-muted);
    font-weight: 400;
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .header-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    padding: var(--space-1) 0;
    transition: color var(--transition-fast);
  }

  .header-btn:hover { color: var(--fg); }

  .header-lang-btn {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    text-decoration: none;
    padding: var(--space-1) 0;
    transition: color var(--transition-fast);
  }

  .header-lang-btn:hover { color: var(--fg); }

  /* Search Overlay */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: color-mix(in srgb, var(--bg) 60%, transparent);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 15vh;
    padding-inline: var(--space-5);
  }

  .search-overlay[hidden] { display: none; }

  .search-box {
    width: 100%;
    max-width: 520px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    animation: fadeIn 0.15s ease;
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-muted);
    gap: var(--space-3);
  }

  .search-icon { color: var(--fg-muted); flex-shrink: 0; }

  #search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--fg);
    caret-color: var(--accent);
  }

  #search-input::placeholder { color: var(--fg-subtle); }

  #search-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--fg-muted);
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast);
  }

  #search-close:hover { color: var(--fg); }

  .search-results {
    padding: var(--space-3) var(--space-3);
    max-height: 380px;
    overflow-y: auto;
  }

  .search-hint, .search-no-results {
    font-size: var(--text-sm);
    color: var(--fg-subtle);
    text-align: center;
    padding: var(--space-6) 0;
  }

  .search-result-item {
    display: block;
    padding: var(--space-3) var(--space-3);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .search-result-item:hover {
    background: var(--card-hover);
  }

  .sr-item-title {
    display: block;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg);
    margin-bottom: 0.2em;
  }

  .sr-item-desc {
    display: block;
    font-size: var(--text-xs);
    color: var(--fg-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 480px) {
    .header-tagline { display: none; }
    .header-btn-text { display: none; }
  }
</style>
