---
import { SITE } from '../config/site';
import { getLang, useTranslations, getLocalePath, languages } from '../i18n/utils';
import ThemeToggle from './ThemeToggle.astro';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const alternateLang = lang === 'en' ? 'zh' : 'en';
const alternatePath = alternateLang === 'zh' ? '/zh/' : '/';

const path = Astro.url.pathname.replace(/\/$/, '');
let currentSection = '';
let currentSectionUrl = '';

if (path.startsWith('/posts/') || path.startsWith('/zh/posts/')) {
  currentSection = t('section.writings');
  currentSectionUrl = getLocalePath(lang, '/posts');
} else if (path.startsWith('/projects/') || path.startsWith('/zh/projects/')) {
  currentSection = t('section.projects');
  currentSectionUrl = getLocalePath(lang, '/projects');
} else if (path.startsWith('/tags/') || path.startsWith('/zh/tags/')) {
  currentSection = t('section.tags');
  currentSectionUrl = getLocalePath(lang, '/tags');
}
---

<header class="site-header" role="banner">
  <div class="header-inner container">
    <!-- Logo / Brand -->
    <div class="header-brand-group">
      <a href={getLocalePath(lang, '/')} class="header-brand" aria-label={SITE.name}>
        <span class="header-logo" aria-hidden="true">SP</span>
        <span class="header-site-name">{SITE.name}</span>
      </a>
      {currentSection && (
        <div class="header-section">
          <span class="header-section-sep">/</span>
          <a href={currentSectionUrl} class="header-section-link">{currentSection}</a>
        </div>
      )}
    </div>

    <!-- Right controls -->
    <nav class="header-controls" aria-label="Site controls">
      <a href={getLocalePath(lang, '/now')} class="header-page-link header-page-link-now">{t('nav.now')}</a>
      <a href={getLocalePath(lang, '/about')} class="header-page-link header-page-link-about">{t('nav.about')}</a>

      {SITE.locale.multiLanguage && (
        <!-- Language switcher (Icon) -->
        <a
          href={alternatePath}
          class="header-tool-btn header-tool-btn-lang"
          aria-label={`Switch to ${alternateLang === 'zh' ? 'Chinese' : 'English'}`}
          hreflang={alternateLang}
          title={languages[alternateLang]}
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m5 8 6 6" />
            <path d="m4 14 6-6 2-3" />
            <path d="M2 5h12" />
            <path d="M7 2h1" />
            <path d="m22 22-5-10-5 10" />
            <path d="M14 18h6" />
          </svg>
        </a>
      )}

      <!-- Search trigger -->
      <button
        id="search-toggle"
        class="header-tool-btn header-tool-btn-search"
        aria-label={t('nav.search')}
        aria-expanded="false"
        aria-controls="search-dialog"
        title={t('nav.search')}
      >
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M10 6.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Zm-.885 3.23a4.5 4.5 0 1 1 .707-.708l2.927 2.927a.5.5 0 0 1-.707.707L9.115 9.73Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
        </svg>
      </button>

      <!-- Theme toggle -->
      <ThemeToggle />
    </nav>
  </div>
</header>

<!-- Search Dialog -->
<div id="search-dialog" class="search-overlay" role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div class="search-box">
    <div class="search-input-wrap">
      <svg width="16" height="16" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="search-icon">
        <path d="M10 6.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Zm-.885 3.23a4.5 4.5 0 1 1 .707-.708l2.927 2.927a.5.5 0 0 1-.707.707L9.115 9.73Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder={t('search.placeholder')}
        autocomplete="off"
        spellcheck="false"
      />
      <button id="search-close" aria-label="Close search">
        <svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M12.854 2.854a.5.5 0 0 0-.708-.708L7.5 6.793 2.854 2.146a.5.5 0 0 0-.708.708L6.793 7.5l-4.647 4.646a.5.5 0 0 0 .708.708L7.5 8.207l4.646 4.647a.5.5 0 0 0 .708-.708L8.207 7.5l4.647-4.646Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
    <div
      id="search-results"
      class="search-results"
      data-no-results={t('search.noResults')}
      data-loading={t('search.loading')}
      data-unavailable={t('search.unavailable')}
      data-empty-hint={t('search.emptyHint')}
      data-post-label={t('search.postLabel')}
      data-project-label={t('search.projectLabel')}
    >
      <p class="search-hint">{t('search.placeholder')}</p>
    </div>
    <div class="search-shortcut" aria-hidden="true">
      <kbd class="search-shortcut-key">⌘K</kbd>
      <span class="search-shortcut-text">to open</span>
      <span class="search-shortcut-text" style="margin-left:0.5em">·</span>
      <kbd class="search-shortcut-key">ESC</kbd>
      <span class="search-shortcut-text">to close</span>
    </div>
  </div>
</div>

<script is:inline>
  // ── Search toggle ─────────────────────────────────────────────────────────
  const toggle = document.getElementById('search-toggle');
  const dialog = document.getElementById('search-dialog');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-input');
  const resultsEl = document.getElementById('search-results');
  const pagefindBundlePath = '/pagefind/pagefind.js';
  const searchMessages = {
    noResults: resultsEl?.getAttribute('data-no-results') ?? 'No results found.',
    loading: resultsEl?.getAttribute('data-loading') ?? 'Loading search index…',
    unavailable: resultsEl?.getAttribute('data-unavailable') ?? 'Search is unavailable.',
    emptyHint: resultsEl?.getAttribute('data-empty-hint') ?? '',
    postLabel: resultsEl?.getAttribute('data-post-label') ?? 'Writing',
    projectLabel: resultsEl?.getAttribute('data-project-label') ?? 'Project',
  };
  let currentLang = document.documentElement.lang || 'en';
  let pagefindModulePromise = null;
  let searchStylesReady = false;

  function ensureSearchStyles() {
    if (searchStylesReady || document.getElementById('search-ui-styles')) {
      searchStylesReady = true;
      return;
    }

    const style = document.createElement('style');
    style.id = 'search-ui-styles';
    style.textContent = `
      .search-overlay {
        position: fixed;
        inset: 0;
        z-index: 200;
        background: rgba(22, 21, 19, 0.36);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding-top: 12vh;
        padding-inline: var(--space-5);
      }

      [data-theme='light'] .search-overlay {
        background: rgba(249, 248, 246, 0.88);
      }

      .search-overlay[hidden] { display: none; }

      .search-box {
        width: 100%;
        max-width: 640px;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
        animation: fadeIn 0.12s ease;
      }

      .search-input-wrap {
        display: flex;
        align-items: center;
        padding: var(--space-4) var(--space-5);
        border-bottom: 1px solid var(--border-muted);
        gap: var(--space-3);
      }

      .search-icon { color: var(--fg-muted); flex-shrink: 0; }

      #search-input {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        font-family: var(--font-sans);
        font-size: var(--text-lg);
        color: var(--fg);
        caret-color: var(--accent);
      }

      #search-input::-webkit-search-decoration,
      #search-input::-webkit-search-cancel-button,
      #search-input::-webkit-search-results-button,
      #search-input::-webkit-search-results-decoration {
        display: none;
      }

      #search-input::placeholder { color: var(--fg-muted); }

      #search-close {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--fg-muted);
        padding: var(--space-1);
        border-radius: var(--radius-sm);
        transition: color var(--transition-fast);
        flex-shrink: 0;
      }

      #search-close:hover { color: var(--fg); }

      .search-results {
        padding: var(--space-2);
        max-height: 480px;
        overflow-y: auto;
      }

      .search-hint, .search-no-results {
        font-size: var(--text-sm);
        color: var(--fg-muted);
        text-align: center;
        padding: var(--space-6) 0;
      }

      .search-empty-state {
        padding: var(--space-8) var(--space-5);
        text-align: center;
      }

      .search-empty-title {
        font-size: var(--text-base);
        font-weight: 500;
        color: var(--fg);
        margin-bottom: var(--space-2);
      }

      .search-empty-body {
        font-size: var(--text-sm);
        color: var(--fg-muted);
        line-height: 1.6;
      }

      .sfg { margin-bottom: var(--space-2); }
      .sfg + .sfg { margin-top: 0; }

      .sfg-file {
        display: flex;
        align-items: flex-start;
        gap: var(--space-3);
        padding: var(--space-4);
        text-decoration: none;
        border-radius: var(--radius-md);
        transition: background 120ms ease, border-color 120ms ease;
        overflow: hidden;
        background: var(--card-bg);
        border: 1px solid var(--border-muted);
      }

      .sfg-file:hover {
        background: var(--card-hover);
        border-color: var(--border);
      }

      .sfg-file-icon {
        flex-shrink: 0;
        margin-top: 2px;
        color: var(--fg-muted);
        opacity: 0.8;
        display: flex;
        align-items: center;
      }

      .sfg-file-info {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .sfg-file-meta {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        min-width: 0;
      }

      .sfg-file-kind {
        display: inline-flex;
        align-items: center;
        padding: 2px 7px;
        border-radius: 999px;
        background: var(--bg-alt);
        border: 1px solid var(--border);
        font-size: 0.62rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: var(--fg-muted);
        flex-shrink: 0;
      }

      .sfg-file-name {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--fg);
        line-height: 1.35;
      }

      .sfg-file-excerpt {
        font-size: 0.8rem;
        color: var(--fg-muted);
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .sfg-file-path {
        font-family: var(--font-mono);
        font-size: 0.68rem;
        color: var(--fg-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
      }

      .sfg-badge {
        flex-shrink: 0;
        align-self: flex-start;
        margin-top: 1px;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        font-weight: 700;
        color: #fff;
        background: var(--accent);
        padding: 1px 6px;
        border-radius: 999px;
        min-width: 18px;
        text-align: center;
        line-height: 1.6;
      }

      .sfg-snips {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 6px 0 0 28px;
      }

      .sfg-snip {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 4px 8px;
        text-decoration: none;
        border-radius: var(--radius-sm);
        transition: background 100ms ease;
      }

      .sfg-snip:hover { background: var(--bg-alt); }

      .sfg-gutter {
        flex-shrink: 0;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--fg-muted);
        width: 14px;
        text-align: right;
        opacity: 0.7;
        user-select: none;
      }

      .sfg-text {
        font-size: 0.76rem;
        color: var(--fg-muted);
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .sfg-text strong {
        color: var(--fg);
        font-weight: 500;
      }

      .sfg-file-name mark,
      .sfg-file-excerpt mark,
      .sfg-text mark {
        background: rgba(178, 69, 52, 0.12);
        color: var(--accent);
        font-weight: 600;
        padding: 0 0.1em;
        border-radius: 2px;
      }

      .search-shortcut {
        display: flex;
        align-items: center;
        gap: var(--space-1);
        padding: var(--space-2) var(--space-5);
        border-top: 1px solid var(--border-muted);
      }

      .search-shortcut-key {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--fg-muted);
        background: var(--bg-alt);
        border: 1px solid var(--border);
        border-radius: 3px;
        padding: 0.1em 0.35em;
      }

      .search-shortcut-text {
        font-size: 0.7rem;
        color: var(--fg-muted);
      }

      @media (max-width: 480px) {
        .search-box { max-width: 100%; }
        .sfg-file { padding: var(--space-3); }
        .sfg-snips { padding-left: 18px; }
      }
    `;
    document.head.appendChild(style);
    searchStylesReady = true;
  }

  function openSearch() {
    if (!dialog || !toggle) return;
    ensureSearchStyles();
    dialog.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => input?.focus());
    document.body.style.overflow = 'hidden';
    void loadPagefind().catch(() => {});
  }

  function closeSearch() {
    if (!dialog || !toggle) return;
    dialog.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    if (input) input.value = '';
    if (resultsEl) renderHint();
  }

  toggle?.addEventListener('click', openSearch);
  closeBtn?.addEventListener('click', closeSearch);
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) closeSearch(); });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
  });

  async function loadPagefind() {
    if (!pagefindModulePromise) {
      pagefindModulePromise = import(/* @vite-ignore */ pagefindBundlePath)
        .then(async (module) => {
          await module.init();
          return module;
        });
    }
    return pagefindModulePromise;
  }

  function escapeHtml(s) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function renderMessage(message, className = 'search-hint') {
    if (!resultsEl) return;
    resultsEl.innerHTML = `<p class="${className}">${escapeHtml(message)}</p>`;
  }

  function renderEmptyState(title, body) {
    if (!resultsEl) return;
    resultsEl.innerHTML = `
      <div class="search-empty-state">
        <p class="search-empty-title">${escapeHtml(title)}</p>
        <p class="search-empty-body">${escapeHtml(body)}</p>
      </div>
    `;
  }

  function renderHint() {
    if (!resultsEl || !input) return;
    resultsEl.innerHTML = `<p class="search-hint">${input.placeholder}</p>`;
  }

  function getResultKind(url) {
    return url.includes('/projects/')
      ? searchMessages.projectLabel
      : searchMessages.postLabel;
  }

  function renderResults(results) {
    if (!resultsEl) return;

    if (results.length === 0) {
      renderEmptyState(searchMessages.noResults, searchMessages.emptyHint);
      return;
    }

    resultsEl.innerHTML = results.map((item) => {
      const icon = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;
      const displayPath = item.url.replace(/^\//, '');
      const kind = getResultKind(item.url);
      const snippets = (item.sub_results?.length ? item.sub_results : [item]).slice(0, 3);
      const summary = item.excerpt || snippets[0]?.excerpt || '';
      const badge = snippets.length;

      const snipRows = snippets.map((snippet, i) =>
        `<a href="${snippet.url}" class="sfg-snip" tabindex="-1"><span class="sfg-gutter">${i + 1}</span><span class="sfg-text">${snippet.title && snippet.title !== item.meta?.title ? `${escapeHtml(snippet.title)} · ` : ''}${snippet.excerpt || ''}</span></a>`
      ).join('');

      return (
        `<div class="sfg">` +
          `<a href="${item.url}" class="sfg-file" aria-label="${escapeHtml(item.meta?.title || item.url)}">` +
            `<span class="sfg-file-icon">${icon}</span>` +
            `<span class="sfg-file-info">` +
              `<span class="sfg-file-meta"><span class="sfg-file-kind">${escapeHtml(kind)}</span><span class="sfg-file-path">${escapeHtml(displayPath)}</span></span>` +
              `<span class="sfg-file-name">${escapeHtml(item.meta?.title || item.url)}</span>` +
              `${summary ? `<span class="sfg-file-excerpt">${summary}</span>` : ''}` +
            `</span>` +
            `<span class="sfg-badge">${badge}</span>` +
          `</a>` +
          `<div class="sfg-snips">${snipRows}</div>` +
        `</div>`
      );
    }).join('');
  }

  input?.addEventListener('input', async () => {
    const query = (input?.value ?? '').trim();
    if (!resultsEl) return;
    if (!query) { renderHint(); return; }
    renderMessage(searchMessages.loading);

    try {
      const pagefind = await loadPagefind();
      const search = await pagefind.debouncedSearch(query, {
        filters: {
          lang: currentLang.startsWith('zh') ? 'zh' : 'en',
          type: {
            any: ['post', 'project'],
          },
        },
      }, 180);

      if (search === null) return;

      const results = await Promise.all(
        search.results.slice(0, 6).map((result) => result.data())
      );

      renderResults(results);
    } catch {
      renderEmptyState(searchMessages.unavailable, searchMessages.emptyHint);
    }
  });

  // ── Scroll Header ─────────────────────────────────────────────────────────
  const siteHeader = document.querySelector('.site-header');
  if (siteHeader) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        siteHeader.classList.add('scrolled');
      } else {
        siteHeader.classList.remove('scrolled');
      }
    }, { passive: true });
  }

</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    inset-inline: 0;
    width: 100%;
    padding-top: var(--space-5);
    padding-bottom: var(--space-3);
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border-muted);
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .site-header.scrolled {
    border-color: var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    gap: var(--space-4);
    min-width: 0;
  }

  .header-brand-group {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
    flex: 1 1 auto;
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--fg);
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
    min-width: 0;
  }

  .header-brand:hover {
    opacity: 0.8;
  }

  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: var(--fg);
    color: var(--bg);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    font-family: var(--font-mono);
  }

  .header-site-name {
    font-size: 1.35rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
    white-space: nowrap;
  }

  .header-section-sep {
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--border);
    user-select: none;
    margin-left: 2px;
    margin-right: 2px;
  }

  .header-section-link {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--fg-muted);
    text-decoration: none;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background-color var(--transition-fast);
    margin-left: -10px; /* Compensate for padding */
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .header-section-link:hover {
    color: var(--fg);
    background: var(--card-hover);
  }

  .header-section {
    display: flex;
    align-items: center;
    min-width: 0;
    flex-shrink: 0;
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 2px; /* Reduced gap to compensate for inner padding of buttons/links */
    flex-shrink: 0;
  }

  .header-page-link {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    text-decoration: none;
    text-transform: uppercase;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .header-page-link:hover {
    color: var(--fg);
    background: var(--card-hover);
  }

  .header-tools {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .header-tool-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: none;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    cursor: pointer;
    color: var(--fg-muted);
    transition: color var(--transition-fast), background-color var(--transition-fast), border-color var(--transition-fast);
  }

