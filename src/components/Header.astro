---
import { SITE } from '../config/site';
import { getLang, useTranslations, getAlternatePath, getLocalePath, languages } from '../i18n/utils';
import ThemeToggle from './ThemeToggle.astro';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const alternateLang = lang === 'en' ? 'zh' : 'en';
const alternatePath = alternateLang === 'zh' ? '/zh/' : '/';
---

<header class="site-header" role="banner">
  <div class="header-inner container">
    <!-- Logo / Brand -->
    <a href={getLocalePath(lang, '/')} class="header-brand" aria-label={SITE.author.name}>
      <span class="header-logo" aria-hidden="true">SP</span>
      <span class="header-site-name">{SITE.author.name}<span class="header-period">.</span></span>
    </a>

    <!-- Right controls -->
    <nav class="header-controls" aria-label="Site controls">
      <!-- Search trigger -->
      <button
        id="search-toggle"
        class="header-btn"
        aria-label={t('nav.search')}
        aria-expanded="false"
        aria-controls="search-dialog"
      >
        <span class="header-btn-text">{t('nav.search')}</span>
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M10 6.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Zm-.885 3.23a4.5 4.5 0 1 1 .707-.708l2.927 2.927a.5.5 0 0 1-.707.707L9.115 9.73Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
        </svg>
      </button>

      <!-- Language switcher -->
      <a
        href={alternatePath}
        class="header-lang-btn"
        aria-label={`Switch to ${alternateLang === 'zh' ? 'Chinese' : 'English'}`}
        hreflang={alternateLang}
      >
        {languages[alternateLang]}
      </a>

      <!-- Theme toggle -->
      <ThemeToggle />
    </nav>
  </div>
</header>

<!-- Search Dialog -->
<div id="search-dialog" class="search-overlay" role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div class="search-box">
    <div class="search-input-wrap">
      <svg width="16" height="16" viewBox="0 0 15 15" fill="none" aria-hidden="true" class="search-icon">
        <path d="M10 6.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0Zm-.885 3.23a4.5 4.5 0 1 1 .707-.708l2.927 2.927a.5.5 0 0 1-.707.707L9.115 9.73Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder={t('search.placeholder')}
        autocomplete="off"
        spellcheck="false"
      />
      <button id="search-close" aria-label="Close search">
        <svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M12.854 2.854a.5.5 0 0 0-.708-.708L7.5 6.793 2.854 2.146a.5.5 0 0 0-.708.708L6.793 7.5l-4.647 4.646a.5.5 0 0 0 .708.708L7.5 8.207l4.646 4.647a.5.5 0 0 0 .708-.708L8.207 7.5l4.647-4.646Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"/>
        </svg>
      </button>
    </div>
    <div id="search-results" class="search-results" role="listbox">
      <p class="search-hint">{t('search.placeholder')}</p>
    </div>
    <div class="search-shortcut" aria-hidden="true">
      <kbd class="search-shortcut-key">⌘K</kbd>
      <span class="search-shortcut-text">to open</span>
      <span class="search-shortcut-text" style="margin-left:0.5em">·</span>
      <kbd class="search-shortcut-key">ESC</kbd>
      <span class="search-shortcut-text">to close</span>
    </div>
  </div>
</div>

<script>
  // ── Search toggle ─────────────────────────────────────────────────────────
  const toggle = document.getElementById('search-toggle');
  const dialog = document.getElementById('search-dialog');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const resultsEl = document.getElementById('search-results');

  function openSearch() {
    if (!dialog || !toggle) return;
    dialog.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    setTimeout(() => input?.focus(), 50);
    document.body.style.overflow = 'hidden';
  }

  function closeSearch() {
    if (!dialog || !toggle) return;
    dialog.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    if (input) input.value = '';
    if (resultsEl) renderHint();
  }

  toggle?.addEventListener('click', openSearch);
  closeBtn?.addEventListener('click', closeSearch);
  dialog?.addEventListener('click', (e) => { if (e.target === dialog) closeSearch(); });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
  });

  // ── Search index ──────────────────────────────────────────────────────────
  type IndexItem = {
    lang: string; type: string; title: string;
    description: string; summary: string; body: string;
    tags: string[]; url: string; pubDatetime: string;
  };
  let searchIndex: IndexItem[] = [];
  let currentLang = document.documentElement.lang || 'en';

  async function loadIndex() {
    if (searchIndex.length > 0) return;
    try {
      const res = await fetch('/search-index.json');
      if (res.ok) searchIndex = await res.json();
    } catch {}
  }

  // ── Highlight & Snippet helpers ───────────────────────────────────────────
  function escapeHtml(s: string) {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function highlight(text: string, query: string): string {
    if (!query) return escapeHtml(text);
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return escapeHtml(text).replace(
      new RegExp(`(${escaped})`, 'gi'),
      '<mark>$1</mark>'
    );
  }

  function getSnippets(text: string, query: string, max = 3): string[] {
    if (!query) return [];
    const q = query.toLowerCase();
    const txt = text.toLowerCase();
    let lastIdx = 0;
    const results: string[] = [];
    while (results.length < max) {
      const idx = txt.indexOf(q, lastIdx);
      if (idx === -1) break;
      
      const start = Math.max(0, idx - 40);
      const end = Math.min(txt.length, idx + q.length + 60);
      
      let snip = text.slice(start, end);
      if (start > 0) snip = '…' + snip;
      if (end < text.length) snip = snip + '…';
      
      results.push(highlight(snip, query));
      lastIdx = end;
    }
    return results;
  }

  // ── Scoring ───────────────────────────────────────────────────────────────
  function scoreItem(item: IndexItem, q: string): number {
    const ql = q.toLowerCase();
    let score = 0;
    if (item.title.toLowerCase().includes(ql)) score += 10;
    if (item.description.toLowerCase().includes(ql)) score += 5;
    if (item.summary.toLowerCase().includes(ql)) score += 4;
    if (item.tags.some(t => t.toLowerCase().includes(ql))) score += 3;
    const bodyMatches = (item.body.toLowerCase().match(new RegExp(ql.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'), 'g')) || []).length;
    score += Math.min(bodyMatches, 8);
    return score;
  }

  // ── Render ────────────────────────────────────────────────────────────────
  function renderHint() {
    if (!resultsEl || !input) return;
    resultsEl.innerHTML = `<p class="search-hint">${input.placeholder}</p>`;
  }

  function renderResults(query: string) {
    if (!resultsEl) return;

    const langFilter = currentLang.startsWith('zh') ? 'zh' : 'en';
    const matches = searchIndex
      .filter(item => item.lang === langFilter && scoreItem(item, query) > 0)
      .map(item => ({ item, score: scoreItem(item, query) }))
      .sort((a, b) => b.score - a.score)
      .slice(0, 6);

    if (matches.length === 0) {
      resultsEl.innerHTML = `<p class="search-no-results">No results for "<strong>${escapeHtml(query)}</strong>"</p>`;
      return;
    }

    resultsEl.innerHTML = matches.map(({ item }) => {
      const titleHtml = highlight(item.title, query);
      // Clean up body
      const cleanBody = item.body
        .replace(/^---[\s\S]*?---/, '')
        .replace(/```[\s\S]*?```/g, '')
        .replace(/[#*`>|[\]()]/g, '')
        .replace(/https?:\/\/\S+/g, '')
        .replace(/[ \t]{2,}/g, ' ')
        .replace(/\n+/g, ' ')
        .trim();

      let snips = getSnippets(cleanBody, query, 3);
      if (snips.length === 0) snips = getSnippets(item.description, query, 1);
      if (snips.length === 0) snips = [escapeHtml(item.description.slice(0, 100)) + (item.description.length > 100 ? '\u2026' : '')];

      // Count total keyword hits
      const re = new RegExp(query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'gi');
      const hits = (cleanBody.match(re) || []).length + (item.description.match(re) || []).length;
      const badge = hits > 0 ? hits : snips.length;

      const icon = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;
      const displayPath = item.url.replace(/^\//, '');

      const snipRows = snips.map((s, i) =>
        `<a href="${item.url}" class="sfg-snip" tabindex="-1"><span class="sfg-gutter">${i + 1}</span><span class="sfg-text">${s}</span></a>`
      ).join('');

      return (
        `<div class="sfg">` +
          `<a href="${item.url}" class="sfg-file" aria-label="${escapeHtml(item.title)}">` +
            `<span class="sfg-file-icon">${icon}</span>` +
            `<span class="sfg-file-info">` +
              `<span class="sfg-file-name">${titleHtml}</span>` +
              `<span class="sfg-file-path">${escapeHtml(displayPath)}</span>` +
            `</span>` +
            `<span class="sfg-badge">${badge}</span>` +
          `</a>` +
          `<div class="sfg-snips">${snipRows}</div>` +
        `</div>`
      );
    }).join('');
  }

  let debounceTimer: ReturnType<typeof setTimeout>;
  input?.addEventListener('input', async () => {
    clearTimeout(debounceTimer);
    const query = (input?.value ?? '').trim();
    if (!resultsEl) return;
    if (!query) { renderHint(); return; }
    await loadIndex();
    debounceTimer = setTimeout(() => renderResults(query), 120);
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: var(--space-8);
    margin-top: var(--space-8);
    z-index: 100;
    background: var(--bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background-color: color-mix(in srgb, var(--bg) 85%, transparent);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    gap: var(--space-4);
  }

  .header-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--fg);
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
  }

  .header-brand:hover {
    opacity: 0.8;
  }

  .header-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: var(--fg);
    color: var(--bg);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    font-family: var(--font-mono);
  }

  .header-site-name {
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .header-period {
    color: var(--accent);
  }



  .header-controls {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .header-btn {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding: var(--space-1) 0;
    transition: color var(--transition-fast);
  }

  .header-btn:hover { color: var(--fg); }

  .header-lang-btn {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--fg-muted);
    text-decoration: none;
    padding: var(--space-1) 0;
    transition: color var(--transition-fast);
  }

  .header-lang-btn:hover { color: var(--fg); }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: color-mix(in srgb, var(--bg) 60%, transparent);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
    padding-inline: var(--space-5);
  }

  .search-overlay[hidden] { display: none; }

  .search-box {
    width: 100%;
    max-width: 640px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.25);
    animation: fadeIn 0.15s ease;
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-muted);
    gap: var(--space-3);
  }

  .search-icon { color: var(--fg-muted); flex-shrink: 0; }

  #search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    color: var(--fg);
    caret-color: var(--accent);
  }

  #search-input::placeholder { color: var(--fg-subtle); }

  #search-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--fg-muted);
    padding: var(--space-1);
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast);
    flex-shrink: 0;
  }

  #search-close:hover { color: var(--fg); }

  .search-results {
    padding: var(--space-2);
    max-height: 480px;
    overflow-y: auto;
  }
</style>

<style is:global>
  .search-hint, .search-no-results {
    font-size: var(--text-sm);
    color: var(--fg-subtle);
    text-align: center;
    padding: var(--space-6) 0;
  }

  /* ─── VS Code–style search results ─────────────────────────────────────────── */

  /* File group container */
  .sfg {
    margin-bottom: 2px;
  }
  .sfg + .sfg {
    border-top: 1px solid var(--border-muted);
    margin-top: 3px;
    padding-top: 3px;
  }

  /* File header row — icon | [name/path col] | badge */
  .sfg-file {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    padding: 4px 8px;
    text-decoration: none;
    border-radius: 3px;
    transition: background 100ms ease;
    overflow: hidden;
  }
  .sfg-file:hover {
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  .sfg-file-icon {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--fg-muted);
    opacity: 0.6;
    display: flex;
    align-items: center;
  }

  /* Column: title on top, path below */
  .sfg-file-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sfg-file-name {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }

  .sfg-file-path {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--fg-subtle);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.2;
  }

  /* Badge — accent pill, right side */
  .sfg-badge {
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    color: #fff;
    background: var(--accent);
    padding: 1px 6px;
    border-radius: 999px;
    min-width: 18px;
    text-align: center;
    line-height: 1.6;
  }

  /* Snippet rows */
  .sfg-snips {
    padding-bottom: 2px;
  }

  .sfg-snip {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 1px 8px 1px 24px;
    text-decoration: none;
    border-radius: 2px;
    transition: background 100ms ease;
  }
  .sfg-snip:hover {
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }

  .sfg-gutter {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--fg-subtle);
    width: 14px;
    text-align: right;
    opacity: 0.7;
    user-select: none;
  }

  .sfg-text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-muted);
    line-height: 1.55;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Keyword highlights */
  .sfg-file-name mark,
  .sfg-text mark {
    background: transparent;
    color: var(--accent);
    font-weight: 700;
  }

  /* search keyboard shortcut hint */
  .search-shortcut {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-5);
    border-top: 1px solid var(--border-muted);
  }

  .search-shortcut-key {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--fg-subtle);
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.1em 0.35em;
  }

  .search-shortcut-text {
    font-size: 0.7rem;
    color: var(--fg-subtle);
  }

  @media (max-width: 480px) {
    .header-btn-text { display: none; }
    .search-box { max-width: 100%; }
  }
</style>
