---
import { SITE } from '../config/site';
import { getLang, useTranslations } from '../i18n/utils';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner container">
    <p class="footer-tagline">{t('footer.tagline')}</p>
    <nav class="footer-links" aria-label="Footer social links">
      <a href={SITE.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <a href={SITE.social.x} target="_blank" rel="noopener noreferrer">X</a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <a href={SITE.social.email}>Email</a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <a href={SITE.social.rss}>RSS</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-20);
    border-top: 1px solid var(--border-muted);
    padding: var(--space-8) 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-tagline {
    font-size: var(--text-xs);
    color: var(--fg-subtle);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-links a {
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-links a:hover { color: var(--fg); }

  .footer-sep {
    color: var(--fg-subtle);
    font-size: var(--text-xs);
  }

  @media (max-width: 480px) {
    .footer-inner { flex-direction: column; align-items: flex-start; gap: var(--space-3); }
  }
</style>
