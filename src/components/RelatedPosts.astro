---
import { getLang, useTranslations } from '../i18n/utils';

interface RelatedPost {
  title: string;
  url: string;
  description: string;
  pubDatetime: Date;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const locale = lang === 'zh' ? 'zh-CN' : 'en-US';
---

{posts.length > 0 && (
  <section class="related-posts container" aria-label={t('post.related')}>
    <div class="related-posts-header">
      <h2>{t('post.related')}</h2>
    </div>

    <div class="related-posts-list">
      {posts.map((post) => (
        <article class="related-post-card">
          <a href={post.url} class="related-post-link">
            <time datetime={post.pubDatetime.toISOString()} class="related-post-date">
              {post.pubDatetime.toLocaleDateString(locale, {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
            <h3 class="related-post-title">{post.title}</h3>
            <p class="related-post-description">{post.description}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .related-posts {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
  }

  .related-posts-header {
    margin-bottom: var(--space-5);
  }

  .related-posts-header h2 {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }

  .related-posts-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .related-post-card {
    border-top: 1px solid var(--border-muted);
  }

  .related-post-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-4);
    min-height: 100%;
  }

  .related-post-title {
    font-size: 1rem;
    line-height: 1.35;
    transition: color var(--transition-fast);
  }

  .related-post-link:hover .related-post-title {
    color: var(--accent);
  }

  .related-post-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-subtle);
  }

  .related-post-description {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .related-posts-list {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
