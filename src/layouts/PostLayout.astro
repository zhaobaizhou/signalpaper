---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Comments from '../components/Comments.astro';
import Newsletter from '../components/Newsletter.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { getLang, useTranslations, getLocalePath } from '../i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'> | CollectionEntry<'projects'>;
  prev?: { title: string; url: string } | null;
  next?: { title: string; url: string } | null;
  relatedPosts?: { title: string; url: string; description: string; pubDatetime: Date }[];
  backUrl?: string;
  backLabel?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { post, prev, next, relatedPosts = [], headings = [] } = Astro.props;
const lang = getLang(Astro.url);
const t = useTranslations(lang);
const isPost = post.collection === 'posts';

const {
  title,
  description,
  pubDatetime,
  modDatetime,
  tags = [],
  featured,
  ogImage,
  canonicalURL,
  summary,
} = post.data as any;

// Reading time estimate — fall back gracefully in Astro v6 glob loader
const rawBody = (post as any).body ?? post.data.summary ?? post.data.description ?? '';
const wordCount = rawBody.split(/\s+/).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const formattedPubDate = pubDatetime.toLocaleDateString(
  lang === 'zh' ? 'zh-CN' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
const formattedModDate = modDatetime?.toLocaleDateString(
  lang === 'zh' ? 'zh-CN' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
  pagefindType={isPost ? 'post' : 'project'}
  article={true}
>
  {isPost && <div class="reading-progress" id="reading-progress" aria-hidden="true"></div>}
  <Header />
  <main id="main-content" role="main">
  <div class="post-layout">
    <header class="post-header container">
      <h1 class="post-title">
        {featured && (
          <svg class="featured-star" xmlns="http://www.w3.org/2000/svg" width="0.85em" height="0.85em" viewBox="0 0 24 24" fill="var(--accent)" aria-label="Featured">
            <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
          </svg>
        )}
        {title}
      </h1>

      {summary
        ? <p class="post-summary">{summary}</p>
        : <p class="post-description">{description}</p>
      }

      <div class="post-meta-bottom">
        {tags.length > 0 ? (
          <div class="post-tags">
            {tags.map((tag: string) => (
              <a href={getLocalePath(lang, `/tags/${tag}`)} class="tag-pill">
                {tag}
              </a>
            ))}
          </div>
        ) : <div></div>}
        
        <div class="post-date-reading">
          <time datetime={pubDatetime.toISOString()} class="post-date">
            {formattedPubDate}
          </time>
          <span class="meta-sep">·</span>
          <span class="post-reading-time">
            {t('post.readingTime', { n: readingMinutes })}
          </span>
        </div>
      </div>

      {modDatetime && (
        <p class="post-updated">
          {t('post.updatedOn')} <time datetime={modDatetime.toISOString()}>{formattedModDate}</time>
        </p>
      )}
    </header>

    <div class="post-divider"></div>

    <article class="prose container fade-in" role="main" id="post-content" data-pagefind-body>
      <slot />
    </article>

    <TableOfContents headings={headings} />

    {isPost && <RelatedPosts posts={relatedPosts} />}

    <footer class="post-footer container">
      {(prev || next) && (
        <nav class="post-nav-adjacent" aria-label="Adjacent posts">
          {prev && (
            <a href={prev.url} class="post-nav-link post-nav-prev">
              <span class="post-nav-dir" aria-hidden="true">←</span>
              <span class="post-nav-meta">{lang === 'zh' ? '上一篇' : 'Previous'}</span>
              <span class="post-nav-title">{prev.title}</span>
            </a>
          )}
          {next && (
            <a href={next.url} class="post-nav-link post-nav-next">
              <span class="post-nav-dir" aria-hidden="true">→</span>
              <span class="post-nav-meta">{lang === 'zh' ? '下一篇' : 'Next'}</span>
              <span class="post-nav-title">{next.title}</span>
            </a>
          )}
        </nav>
      )}

      <Newsletter />
      <Comments />

    </footer>
    </div>
  </main>
  <Footer />

  <!-- Floating Article Toolbar -->
  <aside class="post-fab" id="post-fab" aria-label="Article tools">
    {prev && (
      <a
        href={prev.url}
        class="fab-btn fab-nav"
        data-tooltip={prev.title}
        aria-label={(lang === 'zh' ? '上一篇：' : 'Previous: ') + prev.title}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
    )}
    <button class="fab-btn" id="fab-top" aria-label={lang === 'zh' ? '回到顶部' : 'Back to top'}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
    </button>
    {next && (
      <a
        href={next.url}
        class="fab-btn fab-nav"
        data-tooltip={next.title}
        aria-label={(lang === 'zh' ? '下一篇：' : 'Next: ') + next.title}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    )}
  </aside>

  <script>
    import mediumZoom from 'medium-zoom';

    // 1. Medium Zoom
    mediumZoom('.prose img:not(a img)', {
      margin: 24,
      background: 'var(--bg)'
    });

    // 2. Copy Code Buttons
    const codeBlocks = document.querySelectorAll('.astro-code');
    codeBlocks.forEach((block) => {
      const code = block.querySelector('code');
      const button = document.createElement('button');
      button.className = 'copy-code-btn';
      button.textContent = 'Copy';
      button.setAttribute('aria-label', 'Copy code to clipboard');
      
      button.addEventListener('click', () => {
        const text = code ? code.textContent : block.textContent;
        if (text) {
          navigator.clipboard.writeText(text).then(() => {
            button.textContent = 'Copied!';
            button.classList.add('copied');
            setTimeout(() => {
              button.textContent = 'Copy';
              button.classList.remove('copied');
            }, 2000);
          });
        }
      });
      
      block.appendChild(button);
    });

    // 3. Floating Action Button
    const fab = document.getElementById('post-fab');
    const fabTop = document.getElementById('fab-top');
    const progressBar = document.getElementById('reading-progress');
    const postContent = document.getElementById('post-content');

    // Show toolbar after scrolling past the post header
    const sentinel = document.querySelector('.post-header');
    if (sentinel && fab) {
      const io = new IntersectionObserver(
        ([entry]) => fab.classList.toggle('fab-visible', !entry.isIntersecting),
        { threshold: 0, rootMargin: '-20px 0px 0px 0px' }
      );
      io.observe(sentinel);
    }

    // Back to top
    fabTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    function updateReadingProgress() {
      if (!progressBar || !postContent) return;

      const rect = postContent.getBoundingClientRect();
      const viewportHeight = window.innerHeight;
      const start = window.scrollY + rect.top;
      const end = start + postContent.offsetHeight - viewportHeight;

      if (window.scrollY <= start) {
        progressBar.style.transform = 'scaleX(0)';
        return;
      }

      if (end <= start) {
        progressBar.style.transform = 'scaleX(1)';
        return;
      }

      const progress = Math.min(1, Math.max(0, (window.scrollY - start) / (end - start)));
      progressBar.style.transform = `scaleX(${progress})`;
    }

    if (progressBar && postContent) {
      updateReadingProgress();
      window.addEventListener('scroll', updateReadingProgress, { passive: true });
      window.addEventListener('resize', updateReadingProgress);
    }
  </script>
</BaseLayout>

<style>
  .reading-progress {
    position: fixed;
    inset: 0 0 auto 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left center;
    z-index: 220;
    opacity: 0.85;
    transition: transform 80ms linear;
  }

  .post-layout {
    min-height: 100dvh;
    padding-bottom: var(--space-20);
  }

  .post-header {
    padding-top: var(--space-8);
    padding-bottom: var(--space-2);
  }

  .post-back {
    margin-bottom: var(--space-6);
  }

  .post-back a {
    font-size: var(--text-sm);
    color: var(--fg-muted);
    transition: color var(--transition-fast);
  }

  .post-back a:hover {
    color: var(--accent);
  }

  .post-meta-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-6);
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .post-date-reading {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--fg-muted);
    font-family: var(--font-mono);
  }

  .meta-sep {
    color: var(--border);
  }

  /* Featured star icon */
  .post-title {
    font-size: clamp(1.75rem, 4vw, var(--text-3xl));
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: var(--space-4);
    display: flex;
    align-items: flex-start;
    gap: 0.3em;
  }

  .featured-star {
    flex-shrink: 0;
    color: var(--accent);
    margin-top: 0.15em;
  }

  /* ── Floating article toolbar ─────────────────────────────────────────── */
  .post-fab {
    position: fixed;
    right: max(16px, calc((100vw - var(--content-width)) / 2 - 68px));
    bottom: 48px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 50;
    opacity: 0;
    transform: translateX(6px);
    transition: opacity 200ms ease, transform 200ms ease;
    pointer-events: none;
  }

  .post-fab.fab-visible {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  .fab-btn {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: var(--card-bg);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), box-shadow var(--transition-fast);
    position: relative;
    font-family: inherit;
  }

  .fab-btn:hover {
    background: var(--bg-alt);
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 2px 12px rgba(0,0,0,0.1);
  }

  /* Tooltip: shows article title on hover */
  .fab-nav[data-tooltip]::before {
    content: attr(data-tooltip);
    position: absolute;
    right: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%);
    background: var(--fg);
    color: var(--bg);
    font-size: 0.68rem;
    line-height: 1.4;
    padding: 4px 9px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    max-width: 220px;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0;
    pointer-events: none;
    transition: opacity 150ms ease;
    /* Prevent tooltip overflow on narrow screens */
    transform: translateY(-50%);
  }

  .fab-nav[data-tooltip]:hover::before {
    opacity: 1;
  }

  @media (max-width: 900px) {
    .post-fab {
      right: 12px;
      bottom: 24px;
    }
    /* hide tooltip on mobile — title too long */
    .fab-nav[data-tooltip]::before {
      display: none;
    }
  }

  .post-description,
  .post-summary {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    line-height: 1.6;
    margin-bottom: var(--space-5);
  }

  .post-summary {
    font-style: italic;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-updated {
    font-size: var(--text-sm);
    color: var(--fg-subtle);
  }

  .post-divider {
    border-top: 1px solid var(--border-muted);
    margin: var(--space-4) auto var(--space-6);
    max-width: var(--content-width);
  }

  .prose.container {
    padding-top: 0;
  }

  .post-footer {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-muted);
  }

  .post-footer-tags {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .post-footer-label {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding-top: 0.2em;
    white-space: nowrap;
  }

  .post-footer-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Prev / Next navigation */
  .post-nav-adjacent {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--border-muted);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .post-nav-link:hover {
    border-color: var(--accent);
    background: var(--card-hover);
  }

  .post-nav-next {
    grid-column: 2;
    text-align: right;
    align-items: flex-end;
  }

  .post-nav-prev {
    grid-column: 1;
  }

  /* when only next exists with no prev, push it right */
  .post-nav-next:only-child {
    grid-column: 2;
  }

  .post-nav-dir {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    line-height: 1;
    transition: color var(--transition-fast);
  }

  .post-nav-link:hover .post-nav-dir {
    color: var(--accent);
  }

  .post-nav-meta {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }

  .post-nav-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg);
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .post-nav-adjacent {
      grid-template-columns: 1fr;
    }
    .post-nav-next {
      grid-column: 1;
      text-align: left;
      align-items: flex-start;
    }
  }
