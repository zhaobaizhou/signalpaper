---
import '../styles/global.css';
import { SITE } from '../config/site';
import { getLang } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  article?: boolean;
  noIndex?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage,
  canonicalURL: canonicalProp,
  pubDatetime,
  modDatetime,
  article = false,
  noIndex = false,
} = Astro.props;

const lang = getLang(Astro.url);
const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonicalURL = canonicalProp ?? new URL(Astro.url.pathname, SITE.url).href;
const ogImageURL = ogImage
  ? new URL(ogImage, SITE.url).href
  : new URL('/og-default.png', SITE.url).href;

// Structured data for articles
const articleSchema = article && pubDatetime
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      datePublished: pubDatetime.toISOString(),
      dateModified: (modDatetime ?? pubDatetime).toISOString(),
      author: {
        '@type': 'Person',
        name: SITE.author.name,
        url: SITE.url,
      },
      publisher: {
        '@type': 'Person',
        name: SITE.author.name,
        url: SITE.url,
      },
      url: canonicalURL,
      image: ogImageURL,
      inLanguage: lang,
    })
  : null;

// Site-level structured data
const siteSchema = !article
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: SITE.name,
      url: SITE.url,
      description: SITE.description,
      author: {
        '@type': 'Person',
        name: SITE.author.name,
      },
    })
  : null;
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    {article && pubDatetime && <meta property="article:published_time" content={pubDatetime.toISOString()} />}
    {article && modDatetime && <meta property="article:modified_time" content={modDatetime.toISOString()} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Alternate language -->
    {lang === 'en' && <link rel="alternate" hreflang="zh" href={new URL('/zh' + Astro.url.pathname, SITE.url).href} />}
    {lang === 'zh' && <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace(/^\/zh/, '') || '/', SITE.url).href} />}
    <link rel="alternate" hreflang="x-default" href={new URL('/', SITE.url).href} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Structured Data -->
    {articleSchema && <script type="application/ld+json" set:html={articleSchema} />}
    {siteSchema && <script type="application/ld+json" set:html={siteSchema} />}

    <!-- Theme Script: runs before paint to prevent FOUC -->
    <script is:inline>
      (function () {
        function getTheme() {
          // 1. Check localStorage (user preference)
          const stored = localStorage.getItem('sp-theme');
          if (stored === 'light' || stored === 'dark') return stored;

          // 2. Auto: check local time (6:00–20:00 = light)
          const hour = new Date().getHours();
          if (hour >= 6 && hour < 20) return 'light';

          return 'dark';
        }
        document.documentElement.setAttribute('data-theme', getTheme());
      })();
    </script>
    <!-- Pangu.js: auto-insert spaces between CJK and Latin/numbers -->
    {lang === 'zh' && (
      <script is:inline src="https://cdn.jsdelivr.net/npm/pangu@4.0.7/dist/browser/pangu.min.js"></script>
      <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
          if (typeof pangu !== 'undefined') {
            pangu.spacingPage();
          }
        });
      </script>
    )}
  </head>

  <body>
    <slot />
  </body>
</html>
