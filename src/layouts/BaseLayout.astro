---
import '../styles/global.css';
import { SITE } from '../config/site';
import { getLang } from '../i18n/utils';
import Analytics from '../components/Analytics.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  article?: boolean;
  noIndex?: boolean;
  pagefindType?: 'post' | 'project';
}

const {
  title,
  description = SITE.description,
  ogImage,
  canonicalURL: canonicalProp,
  pubDatetime,
  modDatetime,
  article = false,
  noIndex = false,
  pagefindType,
} = Astro.props;

const lang = getLang(Astro.url);
const defaultTagline = SITE.tagline[lang];
const pageTitle = title
  ? title === SITE.name
    ? SITE.name
    : `${title} — ${SITE.name}`
  : `${SITE.name} — ${defaultTagline}`;
const canonicalURL = canonicalProp ?? new URL(Astro.url.pathname, SITE.url).href;
const ogImageURL = ogImage
  ? new URL(ogImage, SITE.url).href
  : new URL('/og-default.png', SITE.url).href;

// Structured data for articles
const articleSchema = article && pubDatetime
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      datePublished: pubDatetime.toISOString(),
      dateModified: (modDatetime ?? pubDatetime).toISOString(),
      author: {
        '@type': 'Person',
        name: SITE.author.name,
        url: SITE.url,
      },
      publisher: {
        '@type': 'Person',
        name: SITE.author.name,
        url: SITE.url,
      },
      url: canonicalURL,
      image: ogImageURL,
      inLanguage: lang,
    })
  : null;

// Site-level structured data
const siteSchema = !article
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: SITE.name,
      url: SITE.url,
      description,
      author: {
        '@type': 'Person',
        name: SITE.author.name,
      },
    })
  : null;
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <Analytics />

    <!-- Primary Meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    {article && pubDatetime && <meta property="article:published_time" content={pubDatetime.toISOString()} />}
    {article && modDatetime && <meta property="article:modified_time" content={modDatetime.toISOString()} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Alternate language -->
    {SITE.locale.multiLanguage && (
      <>
        {lang === 'en' && <link rel="alternate" hreflang="zh" href={new URL('/zh' + Astro.url.pathname, SITE.url).href} />}
        {lang === 'zh' && <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace(/^\/zh/, '') || '/', SITE.url).href} />}
        <link rel="alternate" hreflang="x-default" href={new URL('/', SITE.url).href} />
      </>
    )}

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Structured Data -->
    {articleSchema && <script is:inline type="application/ld+json" set:html={articleSchema} />}
    {siteSchema && <script is:inline type="application/ld+json" set:html={siteSchema} />}
    <meta data-pagefind-filter={`lang:${lang}`} />
    {pagefindType && <meta data-pagefind-filter={`type:${pagefindType}`} />}

    <!-- Theme Script: runs before paint to prevent FOUC -->
    <script is:inline>
      (function () {
        function getTheme() {
          // 1. Check localStorage (user preference)
          const stored = localStorage.getItem('sp-theme');
          if (stored === 'light' || stored === 'dark') return stored;

          // 2. Auto: check local time (6:00–20:00 = light)
          const hour = new Date().getHours();
          if (hour >= 6 && hour < 20) return 'light';

          return 'dark';
        }
        document.documentElement.setAttribute('data-theme', getTheme());
      })();
    </script>
    <!-- Pangu.js: auto-insert spaces between CJK and Latin/numbers -->
    {lang === 'zh' && (
      <script is:inline src="https://cdn.jsdelivr.net/npm/pangu@4.0.7/dist/browser/pangu.min.js"></script>
      <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
          if (typeof pangu !== 'undefined') {
            pangu.spacingPage();
          }
        });
      </script>
    )}
  </head>

  <body>
    <slot />
    <script is:inline>
      (() => {
        const headingSelector = '.prose :is(h2, h3, h4, h5, h6)';

        function slugify(text, index) {
          const base = text
            .trim()
            .toLowerCase()
            .replace(/[^\p{Letter}\p{Number}\s-]/gu, '')
            .replace(/\s+/g, '-')
            .replace(/-+/g, '-')
            .replace(/^-|-$/g, '');

          return base || `section-${index + 1}`;
        }

        function decorateHeadings() {
          const headings = Array.from(document.querySelectorAll(headingSelector));
          const usedIds = new Set(
            Array.from(document.querySelectorAll('[id]'))
              .map((node) => node.id)
              .filter(Boolean)
          );

          headings.forEach((heading, index) => {
            if (!(heading instanceof HTMLElement)) return;

            if (!heading.id) {
              let slug = slugify(heading.textContent || '', index);
              let suffix = 2;
              while (usedIds.has(slug)) {
                slug = `${slugify(heading.textContent || '', index)}-${suffix}`;
                suffix += 1;
              }
              heading.id = slug;
              usedIds.add(slug);
            }

            heading.classList.add('heading-anchor-target', `heading-anchor-target-level-${heading.tagName.slice(1)}`);

            if (heading.querySelector(':scope > .heading-anchor-link')) return;

            const anchor = document.createElement('a');
            anchor.href = `#${heading.id}`;
            anchor.className = 'heading-anchor-link';
            anchor.setAttribute('aria-label', `Link to heading: ${heading.textContent?.trim() || heading.id}`);

            const label = document.createElement('span');
            label.className = 'heading-anchor-label';
            label.setAttribute('aria-hidden', 'true');
            label.textContent = heading.tagName;

            anchor.appendChild(label);
            heading.prepend(anchor);

            heading.addEventListener('click', (event) => {
              const target = event.target;
              if (!(target instanceof HTMLElement)) return;
              if (target.closest('a') && !target.closest('.heading-anchor-link')) return;

              const hash = `#${heading.id}`;
              if (window.location.hash !== hash) {
                history.pushState(null, '', hash);
              }
              scrollToHashTarget();
            });
          });
        }

        function scrollToHashTarget() {
          if (!window.location.hash) return;
          const target = document.getElementById(decodeURIComponent(window.location.hash.slice(1)));
          const header = document.querySelector('.site-header');
          if (!target) return;

          const headerHeight = header instanceof HTMLElement ? header.getBoundingClientRect().height : 0;
          const top = window.scrollY + target.getBoundingClientRect().top - headerHeight - 15;
          window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
        }

        window.addEventListener('DOMContentLoaded', () => {
          decorateHeadings();
          if (window.location.hash) {
            requestAnimationFrame(() => {
              setTimeout(scrollToHashTarget, 20);
            });
          }
        });

        window.addEventListener('hashchange', scrollToHashTarget);
      })();
    </script>
  </body>
</html>
